// Derived from font8x8 by Daniel Hepper (Public Domain)
// Converted to SMS 4bpp planar format by SmsFontConverter
static const unsigned char retruxel_font_tiles[{{fontTileCount * 32}}] = {
    {{fontTileData}}
};

// ── Character translation table ───────────────────────────────────────────────
// Maps ASCII/Latin codepoint (0x00–0xFF) to tile offset within compact font.
// 0xFF = character not present — renders as blank space.
static const unsigned char retruxel_font_table[256] = {
    {{fontTranslationTable}}
