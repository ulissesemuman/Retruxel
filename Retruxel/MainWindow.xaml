<Window x:Class="Retruxel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Retruxel.Views"
        Title="Retruxel"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="Manual"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/assets/Icons/icon.ico">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          Color="Black" Direction="270"
                          ShadowDepth="8" BlurRadius="32" Opacity="0.6"/>
    </Window.Resources>

    <!-- Outer border — CornerRadius 6 permitido: é a "moldura física" da janela -->
    <Border CornerRadius="6"
            Background="{StaticResource BrushSurface}"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + home button -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0">
                        <Button x:Name="BtnHome"
                                Content="←"
                                Style="{StaticResource ButtonTitleBar}"
                                FontSize="18" FontWeight="Bold"
                                Click="HomeButton_Click"
                                Visibility="Collapsed"
                                Margin="0,0,12,0"
                                ToolTip="Back to Welcome"/>
                        <Image Source="pack://application:,,,/Assets/Images/Logo/RETRUXEL.png"
                               Height="15"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock x:Name="TxtProjectName"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Nav tabs (not yet implemented) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed"/>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0">

                        <!-- Test Wizard -->
                        <Button x:Name="BtnTestWizard"
                                Content="🧙"
                                Style="{StaticResource ButtonTitleBar}"
                                FontSize="16"
                                Margin="0,0,8,0"
                                Click="TestWizard_Click"
                                ToolTip="Test Wizard"/>

                        <!-- Settings -->
                        <Button Content="&#xE713;"
                                Style="{StaticResource ButtonTitleBar}"
                                FontFamily="Segoe MDL2 Assets" FontSize="16"
                                Margin="0,0,16,0"
                                Click="SettingsButton_Click"
                                ToolTip="Settings"/>

                        <!-- Minimize -->
                        <Button Content="─"
                                Style="{StaticResource ButtonTitleBar}"
                                Click="MinimizeButton_Click"/>

                        <!-- Maximize -->
                        <Button Content="□"
                                Style="{StaticResource ButtonTitleBar}"
                                Click="MaximizeButton_Click"/>

                        <!-- Close -->
                        <Button Content="✕"
                                Style="{StaticResource ButtonTitleBarClose}"
                                Click="CloseButton_Click"
                                Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Grid.Row="1" Background="{StaticResource BrushSurface}">

                <Grid>
                    <views:WelcomeView x:Name="WelcomeView"/>
                    <views:SceneEditorView x:Name="SceneEditorView" Visibility="Collapsed"/>
                </Grid>

                <!-- Overlay layer -->
                <Grid x:Name="OverlayLayer"
                      Visibility="Collapsed"
                      Panel.ZIndex="10">

                    <!-- Semi-transparent backdrop (glassmorphism) -->
                    <Border Background="#CC000000" IsHitTestVisible="True"/>

                    <!-- Overlay panel — 0px radius: elemento interno, não moldura -->
                    <Border x:Name="OverlayContent"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            BorderBrush="#3a3a3a"
                            BorderThickness="1"
                            Margin="40"
                            CornerRadius="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Overlay title bar -->
                            <Border Grid.Row="0"
                                    x:Name="OverlayTitleBar"
                                    Background="{StaticResource BrushSurfaceContainerHighest}"
                                    Padding="16,0"
                                    MouseLeftButtonDown="OverlayTitleBar_MouseLeftButtonDown"
                                    Cursor="SizeAll">
                                <Grid>
                                    <TextBlock x:Name="OverlayTitle"
                                               Style="{StaticResource TextLabel}"
                                               VerticalAlignment="Center"/>
                                    <Button Content="✕"
                                            Style="{StaticResource ButtonTitleBarClose}"
                                            HorizontalAlignment="Right"
                                            Click="CloseOverlay_Click"/>
                                </Grid>
                            </Border>

                            <!-- Dynamic overlay content -->
                            <ContentPresenter Grid.Row="1"
                                              x:Name="OverlayContentPresenter"/>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- ===== STATUS BAR ===== -->
            <Border Grid.Row="2"
                    x:Name="StatusBar"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="0,0,6,6"
                    Padding="16,0">
                <Grid>
                    <TextBlock x:Name="TxtVersion"
                               Style="{StaticResource TextLabel}"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
