<Window x:Class="Retruxel.Views.Wizard.CodeGenWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retruxel — CodeGen Wizard"
        Width="800" Height="600"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          Color="Black" Direction="270"
                          ShadowDepth="8" BlurRadius="32" Opacity="0.6"/>
    </Window.Resources>

    <!-- Outer border — CornerRadius 6 permitido: moldura física da janela -->
    <Border CornerRadius="6"
            Background="{StaticResource BrushSurface}"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="24,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="RETRUXEL"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="·"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="CODEGEN WIZARD"
                                   Style="{StaticResource TextHeadline}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            Style="{StaticResource ButtonTitleBarClose}"
                            HorizontalAlignment="Right"
                            Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- ===== BODY ===== -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="64"/>
                </Grid.RowDefinitions>

                <!-- Step header — tonal shift, sem border-line -->
                <Border Grid.Row="0"
                        Background="{StaticResource BrushSurfaceContainerLow}"
                        Padding="24,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="StepTitle"
                                       Text="Step 1: Basic Information"
                                       Style="{StaticResource TextBody}"
                                       Foreground="{StaticResource BrushOnSurface}"/>
                        </StackPanel>

                        <!-- Step indicator -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="StepIndicator"
                                       Text="1 / 4"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushPrimary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step progress track -->
                <Border Height="2"
                        Background="{StaticResource BrushSurfaceContainerHighest}"
                        VerticalAlignment="Bottom"
                        Grid.Row="0">
                    <Border x:Name="ProgressTrack"
                            Background="{StaticResource BrushPrimaryGradient}"
                            HorizontalAlignment="Left"
                            Width="200"/>
                </Border>

                <!-- Content area -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource BrushSurface}">
                    <ContentControl x:Name="ContentArea"
                                    Margin="24"/>
                </ScrollViewer>

                <!-- Footer — tonal shift, sem border-line -->
                <Border Grid.Row="2"
                        Background="{StaticResource BrushSurfaceContainerLow}"
                        Padding="24,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="CANCEL"
                                Style="{StaticResource ButtonGhost}"
                                Padding="24,0" Height="40"
                                Click="Cancel_Click"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BackButton"
                                    Content="← BACK"
                                    Style="{StaticResource ButtonGhost}"
                                    Padding="24,0" Height="40"
                                    IsEnabled="False"
                                    Margin="0,0,8,0"
                                    Click="Back_Click"/>
                            <Button x:Name="NextButton"
                                    Content="NEXT →"
                                    Style="{StaticResource ButtonPrimary}"
                                    Padding="32,0" Height="40"
                                    Click="Next_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
