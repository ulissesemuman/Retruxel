<UserControl x:Class="Retruxel.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Retruxel.Localization"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="16,24">
            <StackPanel>
                <!-- Recent projects header -->
                <TextBlock Text="{loc:Tr Key='welcome.recent_projects'}"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>

                <!-- Recent projects mini list (max 3) -->
                <StackPanel x:Name="SidebarRecentProjects" Margin="0,0,0,16"/>

                <!-- Separator -->
                <Border Height="1" Background="{StaticResource BrushGhostBorder}"
                        Margin="0,0,0,16"/>

                <!-- New project button -->
                <Button Content="{loc:Tr Key='welcome.new_project'}"
                        Background="{StaticResource BrushSecondary}"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="12,10"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Click="NewProject_Click"
                        Cursor="Hand"/>

                <!-- Open project button -->
                <Button Content="{loc:Tr Key='welcome.open_project'}"
                        Background="{StaticResource BrushSecondary}"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="12,10"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,16"
                        Click="OpenProject_Click"
                        Cursor="Hand"/>

                <!-- Separator -->
                <Border Height="1" Background="{StaticResource BrushGhostBorder}"
                        Margin="0,0,0,16"/>

                <!-- Documentation at bottom -->
                <Border Padding="12,10" Margin="0,0,0,4" Cursor="Hand"
                        MouseLeftButtonDown="Documentation_Click">
                    <TextBlock Text="{loc:Tr Key='welcome.documentation'}" Style="{StaticResource TextBody}"/>
                </Border>
                <Border Padding="12,10" Cursor="Hand"
                        MouseLeftButtonDown="About_Click">
                    <TextBlock Text="{loc:Tr Key='welcome.about'}" Style="{StaticResource TextBody}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,32"
                      AllowDrop="True"
                      Drop="MainContent_Drop"
                      DragEnter="MainContent_DragEnter"
                      DragLeave="MainContent_DragLeave">
            <StackPanel>

                <!-- Page title -->
                <TextBlock x:Name="PageTitle"
                           Text="{loc:Tr Key='welcome.title'}"
                           Style="{StaticResource TextDisplay}"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="PageDescription"
                           Text="{loc:Tr Key='welcome.subtitle'}"
                           Style="{StaticResource TextBody}"
                           Margin="0,0,0,32"
                           MaxWidth="600"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>

                <!-- Target selection header -->
                <Grid x:Name="TargetHeader" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="24" Height="2"
                                Background="{StaticResource BrushPrimary}"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{loc:Tr Key='welcome.available_targets'}"
                                   Style="{StaticResource TextLabel}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="COUNT: 01"
                               Style="{StaticResource TextLabel}"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- View toggle + Target cards -->
                <Grid x:Name="TargetCardsSection" Margin="0,0,0,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toggle buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button x:Name="BtnGrid"
                                Content="⊞"
                                Width="32" Height="32"
                                Background="{StaticResource BrushSurfaceContainerHighest}"
                                Foreground="{StaticResource BrushPrimary}"
                                BorderThickness="0"
                                Margin="0,0,4,0"
                                Click="BtnGrid_Click"
                                Cursor="Hand"/>
                        <Button x:Name="BtnList"
                                Content="≡"
                                Width="32" Height="32"
                                Background="{StaticResource BrushSurfaceContainerHigh}"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                Click="BtnList_Click"
                                Cursor="Hand"/>
                    </StackPanel>

                    <!-- Cards container -->
                    <ContentControl x:Name="TargetsPanel"
                                    Grid.Row="1"/>
                </Grid>

                <!-- Recent projects header -->
                <StackPanel x:Name="RecentProjectsHeader" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="24" Height="2"
                            Background="{StaticResource BrushPrimary}"
                            VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{loc:Tr Key='welcome.recent_projects'}"
                               Style="{StaticResource TextLabel}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Recent projects list -->
                <StackPanel x:Name="RecentProjectsPanel"/>

                <!-- Empty state (shown when no recent projects) -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,80,0,0">
                    <TextBlock Text="{loc:Tr Key='welcome.empty.title'}"
                               Style="{StaticResource TextDisplay}"
                               FontSize="48"
                               Foreground="{StaticResource BrushPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Tr Key='welcome.empty.subtitle'}"
                               Style="{StaticResource TextLabel}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                        <Button Content="{loc:Tr Key='welcome.new_project'}"
                                Background="{StaticResource BrushSecondary}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="24,16"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,8,0"
                                Click="NewProject_Click"
                                Cursor="Hand"/>
                        <Button Content="{loc:Tr Key='welcome.open_project'}"
                                Background="{StaticResource BrushSecondary}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="24,16"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="OpenProject_Click"
                                Cursor="Hand"/>
                    </StackPanel>

                    <Border Height="1" Width="300"
                            Background="{StaticResource BrushGhostBorder}"
                            Margin="0,0,0,16"/>
                    <TextBlock Text="{loc:Tr Key='welcome.empty.drag_hint'}"
                               Style="{StaticResource TextLabel}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>