<Window x:Class="Retruxel.Views.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project"
        Height="520" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/assets/Icons/icon.ico">

    <!-- Outer border — CornerRadius 6 permitido: moldura física da janela -->
    <Border CornerRadius="6"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Background="{StaticResource BrushSurfaceContainerLow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="24,0">
                <Grid>
                    <TextBlock x:Name="TxtDialogTitle"
                               Style="{StaticResource TextHeadline}"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            Style="{StaticResource ButtonTitleBarClose}"
                            HorizontalAlignment="Right"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <StackPanel Grid.Row="1" Margin="24,16">

                <!-- Project name -->
                <TextBlock x:Name="TxtProjectNameLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource BrushSurfaceContainerHighest}"
                        Padding="12,0" Margin="0,0,0,24" Height="40">
                    <TextBox x:Name="TxtProjectName"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             Text="my_project"/>
                </Border>

                <!-- Project location -->
                <TextBlock x:Name="TxtLocationLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{StaticResource BrushSurfaceContainerHighest}"
                            Padding="12,0" Height="40" Margin="0,0,8,0">
                        <TextBox x:Name="TxtLocation"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="1"
                            x:Name="BtnBrowse"
                            Style="{StaticResource ButtonToolbar}"
                            Padding="16,0" Height="40"
                            Click="BrowseButton_Click"/>
                </Grid>

                <!-- Target (read-only — set from console selection) -->
                <TextBlock x:Name="TxtTargetLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource BrushSurfaceContainerHighest}"
                        Padding="12,0" Margin="0,0,0,24" Height="40">
                    <TextBlock x:Name="TxtTarget"
                               Style="{StaticResource TextCode}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Template selection -->
                <TextBlock x:Name="TxtTemplateLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,8"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TemplatesPanel"
                                Orientation="Horizontal"/>
                </ScrollViewer>

            </StackPanel>

            <!-- ===== FOOTER ===== -->
            <!-- BrushSurface: tonal shift intencional para ancorar o rodapé -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurface}"
                    CornerRadius="0,0,6,6"
                    Padding="24,0">
                <Grid>
                    <Button x:Name="BtnCancel"
                            Style="{StaticResource ButtonGhost}"
                            HorizontalAlignment="Left"
                            Padding="24,0" Height="40"
                            Click="CloseButton_Click"/>
                    <Button x:Name="BtnCreate"
                            Style="{StaticResource ButtonPrimary}"
                            HorizontalAlignment="Right"
                            Padding="24,0" Height="40"
                            Click="CreateButton_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
