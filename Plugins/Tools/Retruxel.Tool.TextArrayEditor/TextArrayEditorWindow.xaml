<Window x:Class="Retruxel.Tool.TextArrayEditor.TextArrayEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TEXT ARRAY EDITOR"
        Height="620" Width="900"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Retruxel;component/Themes/RetruxelTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DropShadowEffect x:Key="WindowShadow"
                              Color="Black" Direction="270"
                              ShadowDepth="8" BlurRadius="32" Opacity="0.6"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="6"
            Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushOnSurfaceVariant}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="24,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitle"
                                   Text="TEXT ARRAY EDITOR"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock x:Name="TxtArrayName"
                                   Text="— dialog"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushOnSurface}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Click="BtnClose_Click"
                            Style="{StaticResource ButtonTitleBarClose}"/>
                </Grid>
            </Border>

            <!-- TABS -->
            <Border Grid.Row="1"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    BorderBrush="{StaticResource BrushOnSurfaceVariant}"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <StackPanel Orientation="Horizontal" Height="40">
                    <Button x:Name="BtnTabStrings"
                            Content="STRINGS"
                            Click="BtnTabStrings_Click"
                            Style="{StaticResource ButtonGhost}"
                            Padding="16,0"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnTabFont"
                            Content="FONT"
                            Click="BtnTabFont_Click"
                            Style="{StaticResource ButtonGhost}"
                            Padding="16,0"/>
                </StackPanel>
            </Border>

            <!-- CONTENT AREA -->
            <Grid Grid.Row="2">
                <!-- STRINGS TAB -->
                <Grid x:Name="TabStrings" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Array Name + Languages -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ARRAY NAME"
                                           Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                                           Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtArrayNameInput"
                                         TextChanged="TxtArrayNameInput_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="LANGUAGES"
                                           Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                                           Margin="0,0,0,6"/>
                                <StackPanel x:Name="LanguageTabs" Orientation="Horizontal"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Strings List -->
                    <Grid Grid.Row="1" Margin="24,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="12,8"
                                Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="IDX"
                                           Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"/>
                                <TextBlock Grid.Column="1"
                                           Text="STRING"
                                           Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"/>
                                <TextBlock Grid.Column="2"
                                           Text="ACT"
                                           Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Scrollable List -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource BrushSurfaceContainerHigh}">
                            <StackPanel x:Name="StringsList"/>
                        </ScrollViewer>

                        <!-- Add Button -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="12,8"
                                Margin="0,4,0,0">
                            <Button x:Name="BtnAddString"
                                    Content="+ ADD STRING"
                                    Click="BtnAddString_Click"
                                    Style="{StaticResource ButtonGhost}"
                                    HorizontalAlignment="Left"
                                    Padding="12,0"/>
                        </Border>
                    </Grid>

                    <!-- Preview -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            BorderBrush="{StaticResource BrushOnSurfaceVariant}"
                            BorderThickness="0,1,0,0"
                            Padding="24,16"
                            Height="120">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="PREVIEW"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,8"/>

                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushSurface}">
                                <Grid>
                                    <Canvas x:Name="PreviewCanvas"
                                            Background="{StaticResource BrushSurface}"/>
                                    <TextBlock x:Name="TxtPreviewWarning"
                                               Text="⚠ Font not configured — go to the Font tab"
                                               Style="{StaticResource TextLabel}"
                                               Foreground="{StaticResource BrushWarning}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- FONT TAB -->
                <Grid x:Name="TabFont" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Font Asset Path -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="24,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="FONT ASSET"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,6"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{StaticResource BrushSurfaceContainerHigh}"
                                        Padding="12,8">
                                    <TextBlock x:Name="TxtFontPath"
                                               Text="Built-in font8x8 (Public Domain)"
                                               Style="{StaticResource TextCode}"
                                               Foreground="{StaticResource BrushPrimary}"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <Button Grid.Column="2"
                                        x:Name="BtnImportFromTtf"
                                        Content="IMPORT FROM TTF"
                                        Click="BtnImportFromTtf_Click"
                                        Style="{StaticResource ButtonSecondary}"
                                        Padding="16,0"
                                        Height="32"/>

                                <Button Grid.Column="4"
                                        x:Name="BtnBrowseFont"
                                        Content="BROWSE"
                                        Click="BtnBrowseFont_Click"
                                        Style="{StaticResource ButtonSecondary}"
                                        Padding="16,0"
                                        Height="32"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Tileset Preview + ASCII Map -->
                    <Grid Grid.Row="1" Margin="24,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Tileset Preview -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="FONT PREVIEW (220 GLYPHS)"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,8"/>

                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushSurfaceContainerHigh}"
                                    Padding="16">
                                <TextBlock Text="Built-in font8x8 includes:\n• Basic Latin (ASCII 32-127)\n• Extended Latin (accents for PT/ES/FR/DE)\n• Box Drawing (HUD frames)\n\nTotal: 220 characters\nFormat: 8x8 monochrome\nLicense: Public Domain"
                                           Style="{StaticResource TextBody}"
                                           Foreground="{StaticResource BrushOnSurface}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </Grid>

                        <!-- ASCII Map -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="ASCII MAP"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,8"/>

                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushSurfaceContainerHigh}"
                                    BorderBrush="{StaticResource BrushOnSurfaceVariant}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0"
                                            Background="{StaticResource BrushSurfaceContainerHighest}"
                                            Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="CHAR"
                                                       Style="{StaticResource TextLabelCaps}"
                                                       Foreground="{StaticResource BrushOnSurfaceVariant}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="DEC"
                                                       Style="{StaticResource TextLabelCaps}"
                                                       Foreground="{StaticResource BrushOnSurfaceVariant}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="TILE"
                                                       Style="{StaticResource TextLabelCaps}"
                                                       Foreground="{StaticResource BrushOnSurfaceVariant}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Scrollable List -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="AsciiMapList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="12,6"
                                                            Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Char}"
                                                                       Style="{StaticResource TextCode}"
                                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Dec}"
                                                                       Style="{StaticResource TextCode}"
                                                                       Foreground="{StaticResource BrushOnSurfaceVariant}"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Tile}"
                                                                       Style="{StaticResource TextCode}"
                                                                       Foreground="{StaticResource BrushOnSurfaceVariant}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="3"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="0,0,6,6"
                    Padding="24,0">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnCancel"
                                Content="CANCEL"
                                Click="BtnCancel_Click"
                                Style="{StaticResource ButtonGhost}"
                                Padding="24,0" Height="40"
                                Margin="0,0,8,0"/>
                        <Button x:Name="BtnSave"
                                Content="SAVE"
                                Click="BtnSave_Click"
                                Style="{StaticResource ButtonPrimary}"
                                Padding="32,0" Height="40"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
