<Window x:Class="Retruxel.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retruxel"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/icon.ico">

    <Border CornerRadius="6"
            ClipToBounds="True"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Border.Background>
            <ImageBrush ImageSource="pack://application:,,,/Assets/Images/Splash/background.png"
                        Stretch="UniformToFill"
                        AlignmentX="Center"
                        AlignmentY="Center"/>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ===== TOP BAR ===== -->
            <Grid Grid.Row="0" Margin="24,0">
                <TextBlock Text="RETRUXEL_CORE_OS // BOOT_SEQUENCE"
                           Style="{StaticResource TextLabel}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
                <TextBlock Text="SECURE_BOOT_ENABLED"
                           Style="{StaticResource TextLabel}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- ===== CENTER CONTENT ===== -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <!-- Chip icon -->
                <Image Source="pack://application:,,,/Assets/Images/Splash/logochip.png"
                       Width="80" Height="80"
                       Margin="0,0,0,24"
                       HorizontalAlignment="Center"/>

                <!-- App name -->
                <TextBlock Text="RETRUXEL"
                           Style="{StaticResource TextDisplay}"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>

                <!-- Subtitle -->
                <TextBlock Text="RETRO_DEVELOPMENT_SUITE"
                           Style="{StaticResource TextLabel}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- Progress bar -->
                <Grid Width="280" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="StatusLabel"
                               Text="SYSTEM_INITIALIZING"
                               Style="{StaticResource TextLabel}"/>
                    <TextBlock Grid.Column="1"
                               x:Name="PercentLabel"
                               Text="0%"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurface}"/>
                </Grid>

                <Border Width="280" Height="4"
                        Background="{StaticResource BrushSurfaceContainerHighest}"
                        HorizontalAlignment="Center">
                    <Border x:Name="ProgressBar"
                            Background="{StaticResource BrushPrimaryGradient}"
                            HorizontalAlignment="Left"
                            Width="0"/>
                </Border>

                <!-- Log output -->
                <ScrollViewer Width="280" Height="80"
                              Margin="0,16,0,0"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="LogPanel"/>
                </ScrollViewer>

            </StackPanel>

            <!-- ===== BOTTOM BAR ===== -->
            <Grid Grid.Row="3" Margin="24,0">
                <TextBlock x:Name="VersionLabel"
                           Text="v1.0.0-alpha"
                           Style="{StaticResource TextLabel}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

        </Grid>
    </Border>
</Window>