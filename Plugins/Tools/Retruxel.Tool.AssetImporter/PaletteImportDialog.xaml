<Window x:Class="Retruxel.Tool.AssetImporter.PaletteImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PALETTE IMPORT"
        Height="500" Width="480"
        MinHeight="400"
        Background="{StaticResource BrushSurfaceContainerLow}"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Retruxel;component/Themes/RetruxelTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Content ────────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Info -->
                <TextBlock x:Name="TxtInfo"
                           Style="{StaticResource TextBody}"
                           Foreground="{StaticResource BrushOnSurface}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <!-- Action selector -->
                <TextBlock Text="WHAT WOULD YOU LIKE TO DO?"
                           Style="{StaticResource TextLabelCaps}"
                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                           Margin="0,0,0,12"/>

                <StackPanel x:Name="SlotOptionsPanel" Margin="0,0,0,8"/>

                <RadioButton x:Name="RbKeepCurrent"
                             Content="Keep current palette (don't modify slots)"
                             GroupName="PaletteAction"
                             Style="{StaticResource SegmentedRadio}"
                             Margin="0,0,0,24"/>

                <!-- Asset color preview -->
                <TextBlock Text="ASSET COLORS"
                           Style="{StaticResource TextLabelCaps}"
                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                           Margin="0,0,0,8"/>

                <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                        Padding="8">
                    <WrapPanel x:Name="ColorPreviewPanel"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Action bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushSurfaceContainerHigh}"
                Padding="16"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BrushSurfaceContainerHighest}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnCancel"
                        Grid.Column="0"
                        Content="CANCEL"
                        Style="{StaticResource ButtonGhost}"
                        Width="100"
                        HorizontalAlignment="Left"
                        Click="BtnCancel_Click"/>

                <Button x:Name="BtnOk"
                        Grid.Column="1"
                        Content="OK"
                        Style="{StaticResource ButtonPrimary}"
                        Width="100"
                        Click="BtnOk_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
