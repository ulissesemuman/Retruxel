<UserControl x:Class="Retruxel.Views.Wizard.Steps.CodeGenStep2Code"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="CODE TEMPLATE"
                   Style="{StaticResource TextTitle}"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Provide the C code template that will be used to generate code for this module."
                   Style="{StaticResource TextBody}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>

        <!-- Source selection -->
        <TextBlock Text="CODE SOURCE *"
                   Style="{StaticResource TextLabelCaps}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,0,0,4"/>
        <ComboBox x:Name="SourceComboBox" Margin="0,0,0,16" SelectionChanged="SourceComboBox_SelectionChanged">
            <ComboBoxItem Content="Type code now" IsSelected="True"/>
            <ComboBoxItem Content="Attach existing file"/>
        </ComboBox>

        <!-- File picker (hidden by default) -->
        <StackPanel x:Name="FilePickerPanel" Visibility="Collapsed" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathTextBox" IsReadOnly="True" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Content="BROWSE"
                        Style="{StaticResource ButtonGhost}"
                        Click="Browse_Click"
                        Grid.Column="1"
                        Padding="16,0"
                        Height="32"/>
            </Grid>
        </StackPanel>

        <!-- Code editor -->
        <TextBlock Text="CODE CONTENT (use {{variableName}} for placeholders)"
                   Style="{StaticResource TextLabelCaps}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="CodeTextBox"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 FontFamily="Consolas"
                 FontSize="11"
                 Height="300"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Margin="0,0,0,16"/>

        <!-- Info -->
        <Border Background="{StaticResource BrushSurfaceContainerLow}" Padding="16">
            <StackPanel>
                <TextBlock Text="TEMPLATE VARIABLES"
                           Style="{StaticResource TextLabelCaps}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource TextLabel}"
                           Text="Use double curly braces to define variables that will be replaced from module JSON data."/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource TextLabel}"
                           Margin="0,6,0,0"
                           Text="Example: {{text}}, {{x}}, {{y}}, {{color}}"/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource TextLabel}"
                           Margin="0,6,0,0"
                           Text="In the next step, you'll map these variables to JSON paths in the module data."/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
