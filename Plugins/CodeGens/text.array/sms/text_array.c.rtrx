// ── Font init ─────────────────────────────────────────────────────────────────
// Called once in main() OnStart — loads compact font into VRAM
void retruxel_font_init(void) {
    SMS_loadTiles(retruxel_font_tiles,
                  RETRUXEL_FONT_START_TILE,
                  sizeof(retruxel_font_tiles));
}

// ── Print functions ───────────────────────────────────────────────────────────

// Writes a null-terminated string to the nametable at (x, y).
// Characters are translated through the compact font table.
// Non-existent characters render as blank (tile 0 relative to font start).
void retruxel_print(unsigned char x, unsigned char y, const char* str) {
    unsigned int  entry;
    unsigned char col = x;
    unsigned char tile;

    while (*str != '\0') {
        tile  = retruxel_font_table[(unsigned char)*str];
        entry = (unsigned int)(RETRUXEL_FONT_START_TILE + tile);
        SMS_setNextTileatXY(col, y);
        SMS_setTile(entry);
        col++;
        str++;
    }
}

// Writes an unsigned integer as decimal text at (x, y).
// width = number of digit characters (zero-padded on the left).
void retruxel_print_uint(unsigned char x, unsigned char y,
                          unsigned int value, unsigned char width) {
    unsigned char buf[6];
    unsigned char i;
    unsigned char tile;
    unsigned int  entry;

    for (i = 0; i < width; i++) {
        buf[width - 1 - i] = (unsigned char)('0' + value % 10);
        value = value / 10;
    }

    for (i = 0; i < width; i++) {
        tile  = retruxel_font_table[buf[i]];
        entry = (unsigned int)(RETRUXEL_FONT_START_TILE + tile);
        SMS_setNextTileatXY((unsigned char)(x + i), y);
        SMS_setTile(entry);
    }
}
// @retruxel:end
