{{/ifnot}}

{{#if startTile >= 256}}
    // Use second half of VRAM (tiles 256-511) for sprites
    SMS_useFirstHalfTilesforSprites(0);
{{/if}}
{{#if startTile < 256}}
    // Use first half of VRAM (tiles 0-255) for sprites
    SMS_useFirstHalfTilesforSprites(1);
{{/if}}

    SMS_initSprites();
    SMS_copySpritestoSAT();
}

// Call at the beginning of each frame to clear the sprite list
void sprite_begin(void) {
    SMS_initSprites();
}

// Add a sprite to the SAT. tile is relative to startTile.
void sprite_add(unsigned char x, unsigned char y, unsigned char tile) {
