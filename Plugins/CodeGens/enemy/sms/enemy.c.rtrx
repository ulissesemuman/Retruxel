#ifndef ENEMY_{{instanceId}}_H
#define ENEMY_{{instanceId}}_H

#include "entity_{{instanceId}}.h"
{{#if useAnimation}}
#include "animation_{{instanceId}}.h"
{{/if}}

typedef struct {
    int x;
    int y;
    int speed;
    int health;
    int spriteId;
    int direction;
    int patrolOrigin;
    int patrolRange;
} Enemy_{{instanceId}};

void enemy_{{instanceId}}_init(void);
void enemy_{{instanceId}}_update(void);

#endif // ENEMY_{{instanceId}}_H
