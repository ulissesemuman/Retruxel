<Window x:Class="Retruxel.Emulation.EmulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retruxel Emulator (Proof of Concept)" 
        Width="800" Height="600"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#252526" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnLoadCore" Content="LOAD CORE" Width="120" Height="32" Margin="4"/>
                <Button x:Name="BtnLoadRom" Content="LOAD ROM" Width="120" Height="32" Margin="4" IsEnabled="False"/>
                <Button x:Name="BtnRun" Content="RUN" Width="80" Height="32" Margin="4" IsEnabled="False"/>
                <Button x:Name="BtnPause" Content="PAUSE" Width="80" Height="32" Margin="4" IsEnabled="False"/>
                <Button x:Name="BtnReset" Content="RESET" Width="80" Height="32" Margin="4" IsEnabled="False"/>
                <Button x:Name="BtnDumpVram" Content="DUMP VRAM" Width="120" Height="32" Margin="4" IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- Screen -->
        <Border Grid.Row="1" Background="#000000" Margin="8">
            <Image x:Name="ImgScreen" Stretch="Uniform"/>
        </Border>

        <!-- Status -->
        <Border Grid.Row="2" Background="#252526" Padding="8">
            <TextBlock x:Name="TxtStatus" 
                       Text="Ready. Load a libretro core to begin."
                       Foreground="#CCCCCC"
                       FontFamily="Consolas"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>
