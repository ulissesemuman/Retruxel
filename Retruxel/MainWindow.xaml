<Window x:Class="Retruxel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Retruxel.Views"
        Title="Retruxel"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/Assets/icon.ico">

    <Window.Resources>
        <!-- Drop shadow effect for the window -->
        <DropShadowEffect x:Key="WindowShadow"
                          Color="Black"
                          Direction="270"
                          ShadowDepth="8"
                          BlurRadius="32"
                          Opacity="0.6"/>
    </Window.Resources>

    <!-- Outer border — rounded corners + shadow -->
    <Border CornerRadius="6"
            Background="{StaticResource BrushSurface}"
            Effect="{StaticResource WindowShadow}"
            Margin="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0">
                        <!-- Home button (visible only when project is open) -->
                        <Button x:Name="BtnHome"
                                Content="←"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                FontSize="18"
                                FontWeight="Bold"
                                Click="HomeButton_Click"
                                Cursor="Hand"
                                Visibility="Collapsed"
                                Margin="0,0,12,0"
                                ToolTip="Back to Welcome"/>
                        <TextBlock Text="RETRUXEL"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Nav tabs -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="BUILD LOG" Style="{StaticResource TextLabel}"
                                   Cursor="Hand" Margin="0,0,32,0"/>
                        <TextBlock Text="EXPORT" Style="{StaticResource TextLabel}"
                                   Cursor="Hand"/>
                    </StackPanel>   

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0">
                        <Button Content="&#xE713;"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0"
                                Click="SettingsButton_Click"
                                Cursor="Hand"
                                ToolTip="Settings"/>
                        <Button x:Name="BtnGenerateRom"
                                Content="GENERATE ROM"
                                Style="{StaticResource ButtonPrimary}"
                                Padding="16,8" Margin="0,0,8,0"
                                Visibility="Collapsed"/>
                        <!-- Minimize -->
                        <Button Width="32" Height="32"
                                Content="─"
                                Background="Transparent"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                Click="MinimizeButton_Click"
                                Cursor="Hand"/>
                        <!-- Maximize -->
                        <Button Width="32" Height="32"
                                Content="□"
                                Background="Transparent"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                Click="MaximizeButton_Click"
                                Cursor="Hand"/>
                        <!-- Close -->
                        <Button Width="32" Height="32"
                                Content="✕"
                                Background="Transparent"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                Click="CloseButton_Click"
                                Cursor="Hand"
                                Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Grid.Row="1" Background="{StaticResource BrushSurface}">

                <!-- Base layer — always present -->
                <Grid>
                    <views:WelcomeView x:Name="WelcomeView"/>
                    <views:SceneEditorView x:Name="SceneEditorView" Visibility="Collapsed"/>
                </Grid>

                <!-- Overlay layer — shown on top when needed -->
                <Grid x:Name="OverlayLayer" 
                      Visibility="Collapsed"
                      Panel.ZIndex="10">

                    <!-- Semi-transparent backdrop -->
                    <Border Background="#CC000000" IsHitTestVisible="True"/>

                    <!-- Overlay content container -->
                    <Border x:Name="OverlayContent"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Margin="40"
                CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Overlay title bar with close button -->
                            <Border Grid.Row="0"
                                    x:Name="OverlayTitleBar"
                                    Background="{StaticResource BrushSurfaceContainerHighest}"
                                    CornerRadius="6,6,0,0"
                                    Padding="16,0"
                                    MouseLeftButtonDown="OverlayTitleBar_MouseLeftButtonDown"
                                    Cursor="SizeAll">
                                <Grid>
                                    <TextBlock x:Name="OverlayTitle"
                                   Style="{StaticResource TextLabel}"
                                   VerticalAlignment="Center"/>
                                    <Button Content="✕"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                HorizontalAlignment="Right"
                                Click="CloseOverlay_Click"
                                Cursor="Hand"/>
                                </Grid>
                            </Border>

                            <!-- Dynamic overlay content -->
                            <ContentPresenter Grid.Row="1"
                                  x:Name="OverlayContentPresenter"/>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- ===== STATUS BAR ===== -->
            <Border Grid.Row="2"
                    x:Name="StatusBar"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="0,0,6,6"
                    Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="BUILD:" Style="{StaticResource TextLabel}" Margin="0,0,8,0"/>
                        <TextBlock Text="READY" Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushPrimary}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               x:Name="TxtVersion"
                               Style="{StaticResource TextLabel}"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>