{
  "moduleId": "main",
  "targetId": "gg",
  "displayName": "Game Gear Main File Generator",
  "description": "Generates main.c entry point for Sega Game Gear",
  "version": "1.0.0",
  "template": "main.c.rtrx",
  "isSystemModule": true,
  "variables": {
    "projectName": {
      "from": "project",
      "path": "name",
      "default": "Untitled"
    },
    "targetId": {
      "from": "project",
      "path": "targetId",
      "default": "gg"
    },
    "timestamp": {
      "from": "system",
      "value": "{{DateTime.Now:yyyy-MM-dd HH:mm:ss}}"
    },
    "headers": {
      "from": "moduleFiles",
      "filter": "fileType == 'Header'",
      "transform": "#include \"{{fileName}}\""
    },
    "initCalls": {
      "from": "moduleFiles",
      "filter": "fileType == 'Source'",
      "transform": "    {{Path.GetFileNameWithoutExtension(fileName)}}_init();"
    }
  }
}
