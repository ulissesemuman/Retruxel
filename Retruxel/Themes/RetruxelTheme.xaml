<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== FONTS ==================== -->
    <!-- Display & Headlines: Space Grotesk (hardware font) -->
    <FontFamily x:Key="FontDisplay">pack://application:,,,/Assets/Fonts/#Space Grotesk</FontFamily>
    <!-- Body & Labels: Inter (software font) -->
    <FontFamily x:Key="FontBody">pack://application:,,,/Assets/Fonts/#Inter</FontFamily>

    <!-- ==================== COLORS ==================== -->
    <Color x:Key="ColorSurface">#FF0E0E0E</Color>
    <Color x:Key="ColorSurfaceContainerLow">#FF131313</Color>
    <Color x:Key="ColorSurfaceContainerHigh">#FF1E1E1E</Color>
    <Color x:Key="ColorSurfaceContainerHighest">#FF262626</Color>
    <Color x:Key="ColorPrimary">#FF8EFF71</Color>
    <Color x:Key="ColorPrimaryDim">#FF2BE800</Color>
    <Color x:Key="ColorSecondary">#FF7C3AED</Color>
    <Color x:Key="ColorTertiary">#FF81ECFF</Color>
    <Color x:Key="ColorOnSurface">#FFFFFFFF</Color>
    <Color x:Key="ColorOnSurfaceVariant">#FFADAAAA</Color>
    <Color x:Key="ColorOnPrimary">#FF000000</Color>
    <Color x:Key="ColorError">#FFFF4444</Color>
    <Color x:Key="ColorWarning">#FFFFAA00</Color>

    <!-- ==================== BRUSHES ==================== -->
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushSurfaceContainerLow" Color="{StaticResource ColorSurfaceContainerLow}"/>
    <SolidColorBrush x:Key="BrushSurfaceContainerHigh" Color="{StaticResource ColorSurfaceContainerHigh}"/>
    <SolidColorBrush x:Key="BrushSurfaceContainerHighest" Color="{StaticResource ColorSurfaceContainerHighest}"/>
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="BrushPrimaryDim" Color="{StaticResource ColorPrimaryDim}"/>
    <SolidColorBrush x:Key="BrushSecondary" Color="{StaticResource ColorSecondary}"/>
    <SolidColorBrush x:Key="BrushTertiary" Color="{StaticResource ColorTertiary}"/>
    <SolidColorBrush x:Key="BrushOnSurface" Color="{StaticResource ColorOnSurface}"/>
    <SolidColorBrush x:Key="BrushOnSurfaceVariant" Color="{StaticResource ColorOnSurfaceVariant}"/>
    <SolidColorBrush x:Key="BrushOnPrimary" Color="{StaticResource ColorOnPrimary}"/>
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}"/>

    <!-- Action gradient brush — 135deg green CRT effect -->
    <LinearGradientBrush x:Key="BrushPrimaryGradient" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="{StaticResource ColorPrimary}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorPrimaryDim}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Ghost border brush — felt, not seen -->
    <SolidColorBrush x:Key="BrushGhostBorder" Color="#26ADAAAA"/>

    <!-- ==================== TYPOGRAPHY ==================== -->
    <!-- Display: Large data points, screen titles (Space Grotesk Bold) -->
    <Style x:Key="TextDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="Foreground" Value="{StaticResource BrushOnSurface}"/>
    </Style>

    <!-- Headline: Section headers (Space Grotesk SemiBold) -->
    <Style x:Key="TextHeadline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="{StaticResource BrushOnSurface}"/>
    </Style>

    <!-- Label: Small metadata, fine print (Inter Regular) -->
    <Style x:Key="TextLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource BrushOnSurfaceVariant}"/>
    </Style>

    <!-- Body: Technical documentation, dense content (Inter Regular) -->
    <Style x:Key="TextBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource BrushOnSurfaceVariant}"/>
        <Setter Property="LineHeight" Value="19.5"/><!-- 1.5 × 13 = 19.5 -->
    </Style>

    <!-- Code: Monospace for code snippets (Consolas) -->
    <Style x:Key="TextCode" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource BrushPrimary}"/>
    </Style>

    <!-- ==================== BUTTONS ==================== -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushPrimaryGradient}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushOnPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushPrimaryDim}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushOnSurface}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushSurface}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ButtonSecondary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushOnSurface}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== TOGGLE SWITCH ==================== -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Track" Width="36" Height="18"
                                Background="{StaticResource BrushSurfaceContainerHighest}"
                                CornerRadius="0">
                            <Border x:Name="Thumb" Width="14" Height="14"
                                    Background="{StaticResource BrushOnSurfaceVariant}"
                                    CornerRadius="0" Margin="2,0,0,0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background"
                                    Value="{StaticResource BrushPrimary}"/>
                            <Setter TargetName="Thumb" Property="Background"
                                    Value="{StaticResource BrushOnPrimary}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment"
                                    Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin"
                                    Value="0,0,2,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== SCROLLBAR ==================== -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="4"/>
    </Style>

    <!-- ==================== TEXTBOX ==================== -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushOnSurface}"/>
        <Setter Property="CaretBrush" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="SelectionOpacity" Value="0.3"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="4,6,4,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      Margin="{TemplateBinding Padding}"/>
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#8eff71"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== COMBOBOX ==================== -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="#0e0e03"/>
        <Setter Property="Foreground" Value="#8eff71"/>
        <Setter Property="BorderBrush" Value="#3a3a3a"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Grid.Column="0"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="#0e0e03"
                                            BorderBrush="#3a3a3a"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter x:Name="ContentSite"
                                                              Grid.Column="0"
                                                              Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              Margin="8,0"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="▼"
                                                       FontSize="8"
                                                       Foreground="#8eff71"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="8,0,32,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          TextElement.Foreground="#8eff71"/>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="#0e0e03"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="1"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <ScrollViewer MaxHeight="200">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#8eff71"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#262626"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#262626"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>