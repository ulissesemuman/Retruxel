{
  "moduleId": "main",
  "targetId": "sms",
  "displayName": "SMS Main File Generator",
  "description": "Generates main.c entry point for Sega Master System",
  "version": "2.1.0",
  "template": "main.c.rtrx",
  "isSystemModule": true,
  "variables": {
    "projectName": {
      "from": "project",
      "path": "name",
      "default": "Untitled"
    },
    "targetId": {
      "from": "project",
      "path": "targetId",
      "default": "sms"
    },
    "timestamp": {
      "from": "system"
    },
    "headers": {
      "from": "moduleFiles",
      "path": "fileType == 'Header' && sourceModuleId != 'retruxel.core' && sourceModuleId != 'retruxel.splash' && sourceModuleId != 'retruxel.engine'",
      "transform": "#include \"{{fileName}}\""
    },
    "hasTextDisplay": {
      "from": "moduleFiles",
      "path": "sourceModuleId == 'text.display'",
      "transform": "true"
    },
    "updateCalls": {
      "from": "updateCalls"
    },
    "inputCalls": {
      "from": "inputCalls"
    },
    "onStartCalls": {
      "from": "onStartCalls"
    },
    "onVBlankCalls": {
      "from": "onVBlankCalls"
    },
    "splashEnabled": {
      "from": "settings",
      "path": "General.ShowMadeWithSplash",
      "default": true
    }
  }
}
