// ── Compact font tile data ────────────────────────────────────────────────────
// {{fontTileCount}} glyphs × 32 bytes = {{fontTileCount * 32}} bytes
// Loaded into VRAM starting at tile {{fontStartTile}}
static const unsigned char retruxel_font_tiles[] = {
    {{fontTileData}}
};

// ── Character translation table ───────────────────────────────────────────────
// Maps ASCII code (0-255) to tile offset within compact font.
// 0xFF = character not in font (renders as space).
static const unsigned char retruxel_font_table[256] = {
    {{fontTranslationTable}}
};

// ── Text arrays ───────────────────────────────────────────────────────────────
{{#each arrays}}
{{#if ../hasMultiLanguage}}
const char* const text_{{this.name}}[{{this.languages.length}}][{{this.languages[0].strings.length}}] = {
