{
  "moduleId": "sprite",
  "targetId": "sms",
  "displayName": "SMS Sprite CodeGen",
  "description": "Generates C arrays for sprites (simple and metasprites) using flat offset tables",
  "version": "2.0.0",
  "template": "metasprite.c.rtrx",
  "variables": {
    "startTile":    { "from": "module", "path": "startTile",    "default": 256 },
    "tilesAssetId": { "from": "module", "path": "tilesAssetId", "default": "" },
    "paletteRef":   { "from": "module", "path": "paletteRef",   "default": "" },
    "preprocessed": {
      "from": "tool",
      "tool": "metasprite_preprocessor",
      "toolInput": {
        "frames": "frames"
      }
    }
  }
}
