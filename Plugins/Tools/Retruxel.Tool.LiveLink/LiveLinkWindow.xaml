<Window x:Class="Retruxel.Tool.LiveLink.LiveLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LIVE LINK — EMULATOR CAPTURE"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection Section -->
        <Border Grid.Row="0" Background="#242424" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="CONNECTION" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,12"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Emulator:" VerticalAlignment="Center" Foreground="#CCC" Margin="0,0,12,0"/>
                    <ComboBox Grid.Column="1" x:Name="CmbEmulator" Height="32" Background="#2A2A2A" Foreground="#FFF" BorderBrush="#444"/>
                    <Button Grid.Column="2" x:Name="BtnConnect" Content="CONNECT" Width="120" Height="32" Margin="12,0,0,0" 
                            Background="#0078D4" Foreground="#FFF" BorderThickness="0" Click="BtnConnect_Click"/>
                </Grid>
                
                <TextBlock x:Name="TxtStatus" Text="Not connected" Foreground="#888" Margin="0,8,0,0" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Capture Options -->
        <Border Grid.Row="1" Background="#242424" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="CAPTURE OPTIONS" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,12"/>
                
                <CheckBox x:Name="ChkCaptureTiles" Content="Capture Tiles" IsChecked="True" Foreground="#CCC" Margin="0,0,0,8"/>
                <CheckBox x:Name="ChkCaptureNametable" Content="Capture Nametable" IsChecked="True" Foreground="#CCC" Margin="0,0,0,8"/>
                <CheckBox x:Name="ChkCapturePalette" Content="Capture Palette" IsChecked="True" Foreground="#CCC"/>
            </StackPanel>
        </Border>

        <!-- Preview Area -->
        <Border Grid.Row="2" Background="#242424" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PreviewPanel">
                    <TextBlock Text="PREVIEW" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtPreview" Text="No capture yet. Connect to emulator and click CAPTURE." 
                               Foreground="#666" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1" x:Name="BtnCapture" Content="CAPTURE" Width="120" Height="40" Margin="0,0,12,0"
                    Background="#0078D4" Foreground="#FFF" BorderThickness="0" Click="BtnCapture_Click" IsEnabled="False"/>
            <Button Grid.Column="2" x:Name="BtnExport" Content="EXPORT" Width="120" Height="40"
                    Background="#2A2A2A" Foreground="#FFF" BorderThickness="0" Click="BtnExport_Click" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
