<UserControl x:Class="Retruxel.Tool.Wizard.Views.Steps.CodeGenStep4Dependencies"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Dependencies" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
        <TextBlock Text="Specify any tools that this CodeGen depends on (optional)." TextWrapping="Wrap" Margin="0,0,0,24"/>

        <!-- Available tools -->
        <Label Content="Required Tools"/>
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="16" Margin="0,0,0,16">
            <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ToolsPanel">
                    <!-- Tools will be added dynamically -->
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Selected tools -->
        <Label Content="Selected Tools"/>
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="16" MinHeight="80">
            <TextBlock x:Name="SelectedToolsText" 
                       Text="No tools selected" 
                       Foreground="#888888"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Info box -->
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="16" Margin="0,24,0,0">
            <StackPanel>
                <TextBlock Text="ℹ️ Tool Dependencies" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC">
                    If your CodeGen requires specific tools to run (e.g., image converters, data processors),
                    select them here. The build system will ensure these tools are available before running your CodeGen.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,8,0,0">
                    Most CodeGens don't need tool dependencies and can be left empty.
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
