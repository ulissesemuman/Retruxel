<UserControl x:Class="Retruxel.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT — IDENTITY ===== -->
        <Border Grid.Column="0"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="32,40">
            <StackPanel>

                <!-- Logo -->
                <Border Width="80" Height="80"
                        Background="Transparent"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,24">
                    <Image Source="/Assets/Images/Logo/logochip.png"
                           Stretch="Uniform"/>
                </Border>

                <!-- App name -->
                <TextBlock Text="RETRUXEL"
                           Style="{StaticResource TextDisplay}"
                           Foreground="{StaticResource BrushPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="RETRO_DEVELOPMENT_SUITE"
                           Style="{StaticResource TextLabel}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Version -->
                <TextBlock x:Name="TxtVersionLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtVersion"
                           Style="{StaticResource TextBody}"
                           Foreground="{StaticResource BrushOnSurface}"
                           Margin="0,0,0,24"/>

                <!-- Developer -->
                <TextBlock x:Name="TxtDeveloperLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Ulisses Farias"
                           Style="{StaticResource TextBody}"
                           Foreground="{StaticResource BrushOnSurface}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="github.com/ulissesemuman"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Cursor="Hand"
                           MouseLeftButtonDown="DeveloperLink_Click"
                           Margin="0,0,0,24"/>

                <!-- Project -->
                <TextBlock x:Name="TxtProjectLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="github.com/ulissesemuman/Retruxel"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Cursor="Hand"
                           MouseLeftButtonDown="ProjectLink_Click"
                           Margin="0,0,0,32"/>

                <!-- Build -->
                <TextBlock x:Name="TxtBuildLabel"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtBuildDate"
                           Text=".NET 10 / WPF"
                           Style="{StaticResource TextBody}"
                           Foreground="{StaticResource BrushOnSurface}"
                           Margin="0,0,0,32"/>

                <!-- Supported targets -->
                <TextBlock x:Name="TxtSupportedTargets"
                           Style="{StaticResource TextLabelCaps}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource BrushSurfaceContainerHighest}"
                        Padding="8,4" Margin="0,0,0,4"
                        HorizontalAlignment="Left">
                    <TextBlock x:Name="TxtTargetSms"
                               Style="{StaticResource TextCode}"/>
                </Border>
                <TextBlock x:Name="TxtMoreTargets"
                           Style="{StaticResource TextLabel}"
                           Margin="0,8,0,0"/>

            </StackPanel>
        </Border>

        <!-- ===== RIGHT — CREDITS ===== -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="40,32">
            <StackPanel>

                <TextBlock x:Name="TxtCreditsTitle"
                           Style="{StaticResource TextDisplay}"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtCreditsSubtitle"
                           Style="{StaticResource TextBody}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,32"/>

                <!-- Credits cards -->
                <ItemsControl x:Name="CreditsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                                    Padding="20" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name — TextTitle: equivale a TextBody Bold -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Name}"
                                               Style="{StaticResource TextTitle}"/>

                                    <!-- License badge — ciano: informação/leitura -->
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding License}"
                                               Style="{StaticResource TextLabel}"
                                               Foreground="{StaticResource BrushTertiary}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding Description}"
                                               Style="{StaticResource TextBody}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,8"/>

                                    <!-- URL — primary: ação/link -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding Url}"
                                               Style="{StaticResource TextLabel}"
                                               Foreground="{StaticResource BrushPrimary}"
                                               Cursor="Hand"
                                               MouseLeftButtonDown="CreditLink_Click"
                                               Tag="{Binding Url}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Licenses section -->
                <TextBlock x:Name="TxtLicensesTitle"
                           Style="{StaticResource TextHeadline}"
                           Margin="0,32,0,12"/>
                <TextBlock x:Name="TxtLicensesSubtitle"
                           Style="{StaticResource TextBody}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Readonly license text — Consolas 11px intencional para texto de licença -->
                <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                        Height="240">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <TextBox x:Name="TxtLicenses"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
