<Window x:Class="Retruxel.Tool.LiveLink.Windows.PaletteOptimizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PALETTE OPTIMIZATION"
        Width="1000" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushSurfaceContainerLow}"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Retruxel;component/Themes/RetruxelTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushSurfaceContainerHigh}"
                Padding="16,12">
            <TextBlock Text="PALETTE OPTIMIZATION PREVIEW"
                       Style="{StaticResource TextLabelCaps}"
                       Foreground="{StaticResource BrushOnSurface}"/>
        </Border>

        <!-- ── Preview area: original vs optimized ────────────────────────── -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Original -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="ORIGINAL (SOURCE CONSOLE COLORS)"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,0,0,8"/>

                    <Border Grid.Row="1"
                            Background="{StaticResource BrushSurface}">
                        <Image x:Name="ImgOriginal"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Optimized -->
            <Border Grid.Column="2"
                    Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="OPTIMIZED (TARGET PALETTE)"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,0,0,8"/>

                    <Border Grid.Row="1"
                            Background="{StaticResource BrushSurface}">
                        <Image x:Name="ImgOptimized"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Controls: diversity + color space + palette preview ───────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushSurfaceContainerHigh}"
                Padding="16"
                Margin="16,0">
            <StackPanel>

                <!-- Diversity row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="DIVERSITY"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               x:Name="TxtDiversityValue"
                               Text="1.25"
                               Style="{StaticResource TextCode}"
                               Foreground="{StaticResource BrushPrimary}"
                               VerticalAlignment="Center"/>
                </Grid>

                <Slider x:Name="SliderDiversity"
                        Minimum="75"
                        Maximum="125"
                        Value="125"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="SliderDiversity_ValueChanged"/>

                <!-- Slider range labels -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="0.75 (Frequency)"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               HorizontalAlignment="Left"/>

                    <TextBlock Grid.Column="1"
                               Text="1.25 (Distance)"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <!-- Color space selector -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="COLOR SPACE"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <RadioButton x:Name="RbRgb"
                                     Content="RGB"
                                     GroupName="ColorSpace"
                                     Style="{StaticResource SegmentedRadio}"
                                     Checked="ColorSpace_Changed"/>
                        <RadioButton x:Name="RbLab"
                                     Content="LAB"
                                     GroupName="ColorSpace"
                                     IsChecked="True"
                                     Style="{StaticResource SegmentedRadio}"
                                     Checked="ColorSpace_Changed"/>
                    </StackPanel>
                </Grid>

                <!-- Optimized palette swatch strip -->
                <Border Margin="0,16,0,0"
                        Background="{StaticResource BrushSurface}"
                        Padding="8">
                    <StackPanel>
                        <TextBlock Text="OPTIMIZED PALETTE"
                                   Style="{StaticResource TextLabelCaps}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   Margin="0,0,0,8"/>

                        <ItemsControl x:Name="PalettePreview">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="32"
                                            Height="32"
                                            Background="{Binding}"
                                            Margin="0,0,4,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── Action bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushSurfaceContainerHigh}"
                Padding="16"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BrushSurfaceContainerHighest}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel"
                        Content="CANCEL"
                        Style="{StaticResource ButtonGhost}"
                        Width="100"
                        Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnOk"
                        Content="OK"
                        Style="{StaticResource ButtonPrimary}"
                        Width="100"
                        Click="BtnOk_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
