<UserControl x:Class="Retruxel.Views.Wizard.Steps.CodeGenStep3VariableMapping"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="VARIABLE MAPPING"
                   Style="{StaticResource TextTitle}"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Map template variables to JSON paths in the module data."
                   Style="{StaticResource TextBody}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>

        <!-- Detected variables -->
        <TextBlock Text="DETECTED VARIABLES"
                   Style="{StaticResource TextLabelCaps}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,0,0,4"/>
        <Border Background="{StaticResource BrushSurfaceContainerLow}" Padding="16" Margin="0,0,0,16">
            <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="VariablesListBox">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BrushSurfaceContainerHigh}" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Variable name -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding VariableName}" 
                                               FontFamily="Consolas" 
                                               FontSize="14"
                                               Style="{StaticResource TextBody}"
                                               Foreground="{StaticResource BrushPrimary}"
                                               Margin="0,0,0,8"/>
                                    
                                    <!-- JSON Path -->
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="JSON PATH"
                                               Style="{StaticResource TextLabelCaps}"
                                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                             Text="{Binding JsonPath, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Path to the value in module JSON (e.g., parameters.text)"/>
                                    
                                    <!-- Type -->
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="TYPE"
                                               Style="{StaticResource TextLabelCaps}"
                                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                                               VerticalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" 
                                              SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,8,0,0">
                                        <ComboBoxItem Content="string"/>
                                        <ComboBoxItem Content="int"/>
                                        <ComboBoxItem Content="bool"/>
                                        <ComboBoxItem Content="array"/>
                                    </ComboBox>
                                    
                                    <!-- Transformation -->
                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="TRANSFORMATION"
                                               Style="{StaticResource TextLabelCaps}"
                                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                                               VerticalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" 
                                             Text="{Binding Transformation, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Optional transformation (e.g., *Length for string length)"
                                             Margin="0,8,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Common mappings reference -->
        <Border Background="{StaticResource BrushSurfaceContainerLow}" Padding="16">
            <StackPanel>
                <TextBlock Text="COMMON PATTERNS"
                           Style="{StaticResource TextLabelCaps}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="parameters.text" FontFamily="Consolas" Style="{StaticResource TextLabel}" Foreground="{StaticResource BrushPrimary}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="→ String parameter" Style="{StaticResource TextLabel}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="parameters.x" FontFamily="Consolas" Style="{StaticResource TextLabel}" Foreground="{StaticResource BrushPrimary}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="→ Integer parameter" Style="{StaticResource TextLabel}" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="*Length" FontFamily="Consolas" Style="{StaticResource TextLabel}" Foreground="{StaticResource BrushPrimary}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="→ String length transformation" Style="{StaticResource TextLabel}" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="instanceId" FontFamily="Consolas" Style="{StaticResource TextLabel}" Foreground="{StaticResource BrushPrimary}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="→ Auto-generated instance counter" Style="{StaticResource TextLabel}" Margin="0,4,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Text="Note: Variable mapping is optional. Unmapped variables will be left as-is in the template."
                   Style="{StaticResource TextLabel}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,16,0,0"
                   TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
