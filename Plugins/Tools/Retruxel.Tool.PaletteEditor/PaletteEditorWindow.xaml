<Window x:Class="Retruxel.Tool.PaletteEditor.PaletteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1000" Height="600"
        MinWidth="900" MinHeight="500"
        Background="{StaticResource BrushSurfaceContainerLow}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Retruxel;component/Themes/RetruxelTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- ── Three-column content area ──────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Palette list + slot grid ───────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section label -->
                    <TextBlock x:Name="TxtPalettes"
                               Grid.Row="0"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,0,0,8"/>

                    <!-- Palette / slot description (set from code-behind) -->
                    <TextBlock x:Name="TxtPaletteDescription"
                               Grid.Row="1"
                               Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushOnSurface}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- Palette list -->
                    <ListBox x:Name="PaletteListBox"
                             Grid.Row="2"
                             Background="{StaticResource BrushSurfaceContainerLow}"
                             BorderThickness="0"
                             Margin="0,0,0,16"/>

                    <!-- Management buttons -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,16">
                        <Button x:Name="BtnNewPalette"
                                Style="{StaticResource ButtonPrimary}"
                                Margin="0,0,0,8"/>
                        <Button x:Name="BtnDuplicate"
                                Style="{StaticResource ButtonSecondary}"
                                Margin="0,0,0,8"/>
                        <Button x:Name="BtnDelete"
                                Style="{StaticResource ButtonDanger}"/>
                    </StackPanel>

                    <!-- Color slots grid (8×2) -->
                    <Border Grid.Row="4"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="8">
                        <StackPanel>
                            <TextBlock x:Name="TxtSlots"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,8"/>
                            <UniformGrid x:Name="SlotsGrid"
                                         Rows="2"
                                         Columns="8"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- CENTER PANEL: Hardware color picker ────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{StaticResource BrushSurface}"
                    Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtHardwareColors"
                               Grid.Row="0"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,0,0,16"/>

                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <UniformGrid x:Name="HardwareColorGrid"
                                     Rows="8"
                                     Columns="8"
                                     Width="400"
                                     Height="400"/>
                    </Viewbox>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Slot detail + quick set + usage ───────────────── -->
            <Border Grid.Column="2"
                    Background="{StaticResource BrushSurface}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Slot detail -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="12"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="TxtSlotDetail"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtSlotIndex"
                                       Style="{StaticResource TextBody}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtSlotHex"
                                       Style="{StaticResource TextCode}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtSlotRgb"
                                       Style="{StaticResource TextCode}"
                                       Margin="0,0,0,12"/>
                            <Border x:Name="ColorPreview"
                                    Height="48"
                                    Background="{StaticResource BrushSurfaceContainerLow}"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick set -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="12"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="TxtQuickSet"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="BtnSetBlack"
                                    Style="{StaticResource ButtonSecondary}"
                                    Margin="0,0,0,4"/>
                            <Button x:Name="BtnSetWhite"
                                    Style="{StaticResource ButtonSecondary}"
                                    Margin="0,0,0,4"/>
                            <Button x:Name="BtnSetTransparent"
                                    Style="{StaticResource ButtonSecondary}"/>
                        </StackPanel>
                    </Border>

                    <!-- Usage report -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock x:Name="TxtUsage"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       Margin="0,0,0,8"/>
                            <StackPanel x:Name="UsagePanel"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Action bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushSurfaceContainerHigh}"
                Padding="16"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BrushSurfaceContainerHighest}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnCancel"
                        Grid.Column="0"
                        Style="{StaticResource ButtonGhost}"
                        HorizontalAlignment="Left"
                        Width="120"/>
                <Button x:Name="BtnApply"
                        Grid.Column="1"
                        Style="{StaticResource ButtonPrimary}"
                        Width="120"/>
            </Grid>
        </Border>
    </Grid>
</Window>
