<UserControl x:Class="Retruxel.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="16,24">
            <StackPanel>
                <TextBlock Text="PROJECT LIBRARY"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="v1.0.0-alpha"
                           Style="{StaticResource TextLabel}"
                           Margin="0,0,0,32"/>

                <!-- Nav items -->
                <Border Background="{StaticResource BrushSurfaceContainerHighest}"
                        Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                    <TextBlock Text="📁  Assets" Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushOnSurface}"/>
                </Border>
                <Border Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                    <TextBlock Text="⬛  Blocks" Style="{StaticResource TextBody}"/>
                </Border>
                <Border Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                    <TextBlock Text="⚙  Logic" Style="{StaticResource TextBody}"/>
                </Border>
                <Border Padding="12,10" Margin="0,0,0,4" Cursor="Hand">
                    <TextBlock Text="?  Documentation" Style="{StaticResource TextBody}"
                       MouseLeftButtonDown="Documentation_Click"/>
                </Border>                

                <!-- Spacer -->
                <Border Height="1" Background="{StaticResource BrushGhostBorder}"
                        Margin="0,16,0,16"/>

                <!-- New asset button -->
                <Button Content="+ New Asset"
                        Style="{StaticResource ButtonSecondary}"
                        HorizontalAlignment="Stretch"/>

                <!-- Documentation at bottom -->
                <TextBlock Text="? Documentation"
                           Style="{StaticResource TextBody}"
                           Cursor="Hand"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,32">
            <StackPanel>

                <!-- Page title -->
                <TextBlock Text="SYSTEM DASHBOARD"
                           Style="{StaticResource TextDisplay}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Initialize target hardware parameters and access local build archives. Select a core architecture to begin assembly."
                           Style="{StaticResource TextBody}"
                           Margin="0,0,0,32"
                           MaxWidth="600"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>

                <!-- Console selection header -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="24" Height="2"
                                Background="{StaticResource BrushPrimary}"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="CONSOLE SELECTION"
                                   Style="{StaticResource TextLabel}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="AVAILABLE_CORES: 01"
                               Style="{StaticResource TextLabel}"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- View toggle + Console cards -->
                <Grid Margin="0,0,0,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toggle buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button x:Name="BtnGrid"
                                Content="⊞"
                                Width="32" Height="32"
                                Background="{StaticResource BrushSurfaceContainerHighest}"
                                Foreground="{StaticResource BrushPrimary}"
                                BorderThickness="0"
                                Margin="0,0,4,0"
                                Click="BtnGrid_Click"
                                Cursor="Hand"/>
                        <Button x:Name="BtnList"
                                Content="≡"
                                Width="32" Height="32"
                                Background="{StaticResource BrushSurfaceContainerHigh}"
                                Foreground="{StaticResource BrushOnSurfaceVariant}"
                                BorderThickness="0"
                                Click="BtnList_Click"
                                Cursor="Hand"/>
                    </StackPanel>

                    <!-- Cards container -->
                    <WrapPanel x:Name="ConsolesPanel"
                               Grid.Row="1"
                               Orientation="Horizontal"/>
                </Grid>

                <!-- Recent projects header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="24" Height="2"
                            Background="{StaticResource BrushPrimary}"
                            VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="RECENT PROJECTS"
                               Style="{StaticResource TextLabel}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Recent projects list -->
                <StackPanel x:Name="RecentProjectsPanel"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>