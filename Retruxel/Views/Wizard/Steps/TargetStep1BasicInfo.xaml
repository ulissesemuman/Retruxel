<UserControl x:Class="Retruxel.Views.Wizard.Steps.TargetStep1BasicInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="BASIC INFORMATION" 
                   Style="{StaticResource TextTitle}"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Provide the basic information about your target console." 
                   Style="{StaticResource TextBody}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   TextWrapping="Wrap" 
                   Margin="0,0,0,24"/>

        <!-- Console Database Quick Fill — tonal shift, sem borda -->
        <Border Background="{StaticResource BrushSurfaceContainerLow}" 
                Padding="16" 
                Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="QUICK FILL"
                           Style="{StaticResource TextLabelCaps}"
                           Foreground="{StaticResource BrushPrimary}" 
                           Margin="0,0,0,4"/>
                <TextBlock Text="Select a console from the database to auto-fill specs" 
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushOnSurfaceVariant}" 
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="ConsoleComboBox" 
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          Height="36"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Target ID -->
            <TextBlock Style="{StaticResource TextLabelCaps}"
                   Grid.Row="0" 
                   Grid.Column="0" 
                   Text="TARGET ID *"
                   Foreground="{StaticResource BrushOnSurfaceVariant}" 
                   Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="0" x:Name="TargetIdTextBox" Margin="0,0,0,12"/>

            <!-- Display Name -->
            <TextBlock Style="{StaticResource TextLabelCaps}" Grid.Row="0" Grid.Column="2" Text="DISPLAY NAME *" Foreground="{StaticResource BrushOnSurfaceVariant}" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="2" x:Name="DisplayNameTextBox" Margin="0,0,0,12"/>

            <!-- Manufacturer -->
            <TextBlock Style="{StaticResource TextLabelCaps}" Grid.Row="2" Grid.Column="0" Text="MANUFACTURER *" Foreground="{StaticResource BrushOnSurfaceVariant}" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" Grid.Column="0" x:Name="ManufacturerTextBox" Margin="0,0,0,12"/>

            <!-- Release Year -->
            <TextBlock Style="{StaticResource TextLabelCaps}" Grid.Row="2" Grid.Column="2" Text="RELEASE YEAR" Foreground="{StaticResource BrushOnSurfaceVariant}" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" Grid.Column="2" x:Name="ReleaseYearTextBox" Text="1980" Margin="0,0,0,12"/>

            <!-- Status -->
            <TextBlock Style="{StaticResource TextLabelCaps}" Grid.Row="4" Grid.Column="0" Text="STATUS" Foreground="{StaticResource BrushOnSurfaceVariant}" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="5" Grid.Column="0" x:Name="StatusComboBox" Margin="0,0,0,12">
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Scaffolding" IsSelected="True"/>
                <ComboBoxItem Content="Planned"/>
            </ComboBox>
        </Grid>

        <!-- Description -->
        <TextBlock Style="{StaticResource TextLabelCaps}" Text="DESCRIPTION" Foreground="{StaticResource BrushOnSurfaceVariant}" Margin="0,0,0,4"/>
        <TextBox x:Name="DescriptionTextBox" 
                 TextWrapping="Wrap" 
                 AcceptsReturn="True" 
                 Height="80" 
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,12"/>

        <TextBlock Text="* Required fields" 
                   Style="{StaticResource TextLabel}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}" 
                   Margin="0,4,0,0"/>
    </StackPanel>
</UserControl>
