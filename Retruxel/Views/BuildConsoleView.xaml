<UserControl x:Class="Retruxel.Views.BuildConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT — TERMINAL ===== -->
        <Grid Grid.Column="0" Margin="32,24,16,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="BUILD " Style="{StaticResource TextDisplay}"/>
                <TextBlock Text="CONSOLE" Style="{StaticResource TextDisplay}"
                           Foreground="{StaticResource BrushPrimary}"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       x:Name="TxtDescription"
                       Text="Ready to compile."
                       Style="{StaticResource TextBody}"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"/>

            <!-- Status -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="STATUS:" Style="{StaticResource TextLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Width="8" Height="8"
                            Background="{StaticResource BrushPrimary}"
                            Margin="0,0,8,0" VerticalAlignment="Center"
                            x:Name="StatusDot"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="READY"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushPrimary}"/>
                </StackPanel>
            </Grid>

            <!-- Terminal -->
            <Border Grid.Row="3"
                    Background="{StaticResource BrushSurfaceContainerHigh}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Terminal title bar -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerHighest}"
                            Padding="12,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="10" Height="10" Background="#FF4444"
                                        Margin="0,0,6,0"/>
                                <Border Width="10" Height="10" Background="#FFAA00"
                                        Margin="0,0,6,0"/>
                                <Border Width="10" Height="10"
                                        Background="{StaticResource BrushPrimary}"/>
                            </StackPanel>
                            <Button Content="💾"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource BrushOnSurfaceVariant}"
                                    FontSize="14"
                                    Padding="8,0"
                                    Cursor="Hand"
                                    Click="ExportLog_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource BrushPrimary}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Log output -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="LogScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel x:Name="LogPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== RIGHT — EXPORT + STATS ===== -->
        <StackPanel Grid.Column="1" Margin="16,24,32,24">

            <!-- Export options -->
            <TextBlock Text="EXPORT OPTIONS"
                       Style="{StaticResource TextLabel}"
                       Margin="0,48,0,12"/>

            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16" Margin="0,0,0,8"
                    Cursor="Hand"
                    x:Name="ExportRomCard"
                    MouseLeftButtonDown="ExportRom_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="STANDARD ROM (.sms)"
                                   Style="{StaticResource TextBody}"
                                   Foreground="{StaticResource BrushOnSurface}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="For emulators and flash carts"
                                   Style="{StaticResource TextLabel}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="↓"
                               FontSize="18"
                               Foreground="{StaticResource BrushPrimary}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16" Margin="0,0,0,24"
                    Cursor="Hand"
                    x:Name="ExportDebugCard"
                    MouseLeftButtonDown="ExportDebug_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DEBUG PACKAGE (.zip)"
                                   Style="{StaticResource TextBody}"
                                   Foreground="{StaticResource BrushOnSurface}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Incl. source files and build log"
                                   Style="{StaticResource TextLabel}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="⬛"
                               FontSize="14"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Verification -->
            <Border Background="{StaticResource BrushSecondary}"
                    Padding="16" x:Name="VerificationPanel"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="VERIFICATION"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurface}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="MD5 HASH" Style="{StaticResource TextLabel}"/>
                        <TextBlock x:Name="TxtMd5"
                                   Style="{StaticResource TextCode}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="SHA-256" Style="{StaticResource TextLabel}"/>
                        <TextBlock x:Name="TxtSha256"
                                   Style="{StaticResource TextCode}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock x:Name="TxtChecks"
                               Text="✓ ALL CHECKS PASSED"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushPrimary}"/>
                </StackPanel>
            </Border>

            <!-- Memory stats -->
            <TextBlock Text="MEMORY ALLOCATION"
                       Style="{StaticResource TextLabel}"
                       Margin="0,24,0,12"
                       x:Name="MemoryHeader"
                       Visibility="Collapsed"/>

            <StackPanel x:Name="MemoryPanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="PRG-ROM" Style="{StaticResource TextLabel}"/>
                    <TextBlock x:Name="TxtRomSize"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurface}"
                               HorizontalAlignment="Right"/>
                </Grid>
                <Border Height="4" Background="{StaticResource BrushSurfaceContainerHighest}"
                        Margin="0,0,0,12">
                    <Border x:Name="RomSizeBar"
                            Background="{StaticResource BrushPrimaryGradient}"
                            HorizontalAlignment="Left" Width="0"/>
                </Border>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>