// ── Font init ─────────────────────────────────────────────────────────────────
// Call once in main() OnStart — loads compact font into VRAM
void retruxel_font_init(void) {
    SMS_loadTiles(retruxel_font_tiles,
                  RETRUXEL_FONT_START_TILE,
                  sizeof(retruxel_font_tiles));
}

// ── Print functions ───────────────────────────────────────────────────────────

// Writes null-terminated string to nametable at tile position (x, y).
// Translates each char through compact font table before writing.
// Chars not in font render as blank (0xFF entry = tile 0 of font = space).
void retruxel_print(unsigned char x, unsigned char y, const char* str) {
    unsigned char col = x;
    unsigned int  entry;
    unsigned char tile;

    while (*str != '\0') {
        tile  = retruxel_font_table[(unsigned char)*str];
        entry = (unsigned int)(RETRUXEL_FONT_START_TILE +
                               (tile == 0xFF ? 0 : tile));
        SMS_setNextTileatXY(col, y);
        SMS_setTile(entry);
        col++;
        str++;
    }
}

// Writes unsigned int as zero-padded decimal at tile position (x, y).
// width = number of digit characters to write (e.g. 5 for "00042").
void retruxel_print_uint(unsigned char x, unsigned char y,
                          unsigned int value, unsigned char width) {
    unsigned char buf[6]; // max 5 digits + safety
    unsigned char i;
    unsigned char tile;
    unsigned int  entry;

    for (i = 0; i < width; i++) {
        buf[width - 1 - i] = (unsigned char)('0' + value % 10);
        value /= 10;
    }

    for (i = 0; i < width; i++) {
        tile  = retruxel_font_table[buf[i]];
        entry = (unsigned int)(RETRUXEL_FONT_START_TILE +
                               (tile == 0xFF ? 0 : tile));
        SMS_setNextTileatXY((unsigned char)(x + i), y);
        SMS_setTile(entry);
    }
}
// @retruxel:end
