<UserControl x:Class="Retruxel.Views.SceneEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Retruxel.Localization"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Scene tabs -->
                <ScrollViewer Grid.Column="0"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Stretch">
                    <StackPanel x:Name="SceneTabsPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch"/>
                </ScrollViewer>

                <!-- Coordinates display -->
                <TextBlock Grid.Column="1"
                           x:Name="TxtCoordinates"
                           Text="X: 0 | Y: 0"
                           Style="{StaticResource TextLabel}"
                           VerticalAlignment="Center"
                           Margin="16 0"/>

                <!-- Generate ROM -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0 0 12 0">
                    
                    <!-- Save indicator -->
                    <TextBlock x:Name="TxtSaveIndicator"
                               Text="💾"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0 0 8 0"
                               Opacity="0.3"
                               ToolTip="Auto-save"/>
                    
                    <Button x:Name="BtnUndo"
                            Content="↩"
                            IsEnabled="False"
                            ToolTip="Nothing to undo"
                            Style="{StaticResource ButtonTitleBar}"
                            Click="BtnUndo_Click"/>
                    <Button x:Name="BtnRedo"
                            Content="↪"
                            IsEnabled="False"
                            ToolTip="Nothing to redo"
                            Style="{StaticResource ButtonTitleBar}"
                            Click="BtnRedo_Click"/>
                    <Button x:Name="BtnGenerateRom"
                            Content="{loc:Tr Key='scene.generate_rom'}"
                            Style="{StaticResource ButtonPrimary}"
                            Padding="16,0" Height="28"
                            Click="GenerateRom_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== LEFT — SIDEBAR ===== -->
        <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2"
                Background="{StaticResource BrushSurfaceContainerLow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tab headers -->
                <Grid Grid.Row="0" Background="{StaticResource BrushSurface}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnTabStructure"
                            Grid.Column="0"
                            Content="STRUCTURE"
                            Click="BtnTabStructure_Click"
                            Tag="active"
                            Style="{StaticResource SidebarTab}"/>

                    <Button x:Name="BtnTabModules"
                            Grid.Column="1"
                            Content="{loc:Tr Key='scene.modules'}"
                            Click="BtnTabModules_Click"
                            Style="{StaticResource SidebarTab}"/>
                </Grid>

                <!-- ── STRUCTURE panel ── -->
                <ScrollViewer x:Name="PanelStructure"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StructurePanel" Margin="0 8 0 0"/>
                </ScrollViewer>

                <!-- ── MODULES panel ── -->
                <ScrollViewer x:Name="PanelModules"
                              Grid.Row="1"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0 8 0 0">
                        <TextBlock Text="{loc:Tr Key='scene.system_status'}"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   Margin="12,4,12,16"
                                   FontSize="9"/>

                        <TextBlock Text="{loc:Tr Key='scene.modules'}"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   Margin="12,0,12,8"/>

                        <StackPanel x:Name="ModulePalettePanel"/>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- ===== CENTER — CANVAS ===== -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource BrushSurface}">
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="40">

                <!-- Canvas outer glow border -->
                <Border BorderBrush="{StaticResource BrushGhostBorder}"
                        BorderThickness="1"
                        Padding="1">

                    <!-- Screen area — size set dynamically from target specs -->
                    <Canvas x:Name="SceneCanvas"
                            ClipToBounds="True"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            AllowDrop="True"
                            Drop="Canvas_Drop"
                            DragOver="Canvas_DragOver">

                        <!-- Checkerboard pattern via DrawingBrush -->
                        <Canvas.Background>
                            <DrawingBrush TileMode="Tile"
                                          Viewport="0,0,16,16"
                                          ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#FF0D0D0D">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,16,16"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#FF111111">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,8,8"/>
                                                    <RectangleGeometry Rect="8,8,8,8"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Canvas.Background>

                        <!-- Canvas elements added here dynamically -->

                    </Canvas>
                </Border>

                <!-- Canvas size label -->
                <TextBlock x:Name="TxtCanvasSize"
                           Style="{StaticResource TextLabel}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,4,0,-16"/>
            </Grid>
        </ScrollViewer>

        <!-- ===== RIGHT — PROPERTIES ===== -->
        <Border Grid.Row="1" Grid.Column="2"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{loc:Tr Key='scene.properties'}"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Empty state -->
                        <TextBlock Text="{loc:Tr Key='scene.no_selection'}"
                                   x:Name="TxtNoSelection"
                                   Style="{StaticResource TextBody}"
                                   TextWrapping="Wrap"
                                   Visibility="Visible"/>

                        <!-- Properties content — shown when element selected -->
                        <StackPanel x:Name="PropertiesPanel"
                                    Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>