<Window x:Class="Retruxel.Views.TargetSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Retruxel.Controls"
        xmlns:loc="clr-namespace:Retruxel.Localization"
        Title="{loc:Tr Key='targetselection.title'}"
        Height="600" Width="759"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <!-- Outer border — CornerRadius 6 permitido: moldura física da janela -->
    <Border CornerRadius="6"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Background="{StaticResource BrushSurfaceContainerLow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="24,0">
                <Grid>

                    <TextBlock Text="{loc:Tr Key='targetselection.title'}"
                               Style="{StaticResource TextHeadline}"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            Style="{StaticResource ButtonTitleBarClose}"
                            HorizontalAlignment="Right"
                            Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <Grid Grid.Row="1" Margin="24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{loc:Tr Key='targetselection.description'}"
                           Grid.Row="0"
                           Style="{StaticResource TextBody}"
                           Margin="0,0,0,16"/>

                <controls:TargetGridControl x:Name="TargetGrid"
                                            Grid.Row="1"
                                            TargetSelected="TargetGrid_TargetSelected"/>
            </Grid>

            <!-- ===== FOOTER ===== -->
            <!-- BrushSurface no footer: tonal shift intencional, ancora o rodapé -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurface}"
                    CornerRadius="0,0,6,6"
                    Padding="24,0">
                <Button x:Name="BtnCancel"
                        Content="{loc:Tr Key='targetselection.cancel'}"
                        Style="{StaticResource ButtonGhost}"
                        HorizontalAlignment="Right"
                        Padding="24,0" Height="40"
                        Click="Cancel_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
