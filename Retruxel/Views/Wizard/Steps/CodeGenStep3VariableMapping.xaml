<UserControl x:Class="Retruxel.Views.Wizard.Steps.CodeGenStep3VariableMapping"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Variable Mapping" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
        <TextBlock Text="Map template variables to JSON paths in the module data." TextWrapping="Wrap" Margin="0,0,0,24"/>

        <!-- Detected variables -->
        <Label Content="Detected Variables"/>
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="16" Margin="0,0,0,16">
            <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="VariablesListBox">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Variable name -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding VariableName}" 
                                               FontFamily="Consolas" 
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#4EC9B0"
                                               Margin="0,0,0,8"/>
                                    
                                    <!-- JSON Path -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="JSON Path:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                             Text="{Binding JsonPath, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Path to the value in module JSON (e.g., parameters.text)"/>
                                    
                                    <!-- Type -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" 
                                              SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,8,0,0">
                                        <ComboBoxItem Content="string"/>
                                        <ComboBoxItem Content="int"/>
                                        <ComboBoxItem Content="bool"/>
                                        <ComboBoxItem Content="array"/>
                                    </ComboBox>
                                    
                                    <!-- Transformation -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Transformation:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" 
                                             Text="{Binding Transformation, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Optional transformation (e.g., *Length for string length)"
                                             Margin="0,8,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Common mappings reference -->
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Text="📋 Common Patterns" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="parameters.text" FontFamily="Consolas" Foreground="#4EC9B0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="→ String parameter" Foreground="#CCCCCC"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="parameters.x" FontFamily="Consolas" Foreground="#4EC9B0" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="→ Integer parameter" Foreground="#CCCCCC" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="*Length" FontFamily="Consolas" Foreground="#4EC9B0" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="→ String length transformation" Foreground="#CCCCCC" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="instanceId" FontFamily="Consolas" Foreground="#4EC9B0" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="→ Auto-generated instance counter" Foreground="#CCCCCC" Margin="0,4,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Text="Note: Variable mapping is optional. Unmapped variables will be left as-is in the template." 
                   FontSize="10" 
                   Foreground="#888888" 
                   Margin="0,16,0,0"
                   TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
