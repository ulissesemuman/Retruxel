<UserControl x:Class="Retruxel.Tool.Wizard.Views.Steps.TargetStep2Specs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Technical Specifications" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
            <TextBlock Text="Define the hardware specifications of your target console." TextWrapping="Wrap" Margin="0,0,0,24"/>

            <!-- CPU -->
            <TextBlock Text="CPU &amp; MEMORY" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="CPU *"/>
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="CpuTextBox" Margin="0,0,0,12"/>

                <Label Grid.Row="0" Grid.Column="2" Content="CPU Clock (Hz) *"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="CpuClockTextBox" Margin="0,0,0,12"/>

                <Label Grid.Row="2" Grid.Column="0" Content="RAM (bytes)"/>
                <TextBox Grid.Row="3" Grid.Column="0" x:Name="RamTextBox" Text="8192"/>

                <Label Grid.Row="2" Grid.Column="2" Content="VRAM (bytes)"/>
                <TextBox Grid.Row="3" Grid.Column="2" x:Name="VramTextBox" Text="16384"/>
            </Grid>

            <!-- DISPLAY -->
            <TextBlock Text="DISPLAY" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Screen Width *"/>
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="ScreenWidthTextBox" Text="256" Margin="0,0,0,12"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Screen Height *"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="ScreenHeightTextBox" Text="192" Margin="0,0,0,12"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Tile Width"/>
                <TextBox Grid.Row="3" Grid.Column="0" x:Name="TileWidthTextBox" Text="8"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Tile Height"/>
                <TextBox Grid.Row="3" Grid.Column="2" x:Name="TileHeightTextBox" Text="8"/>
            </Grid>

            <!-- COLORS -->
            <TextBlock Text="COLORS &amp; PALETTES" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Total Colors"/>
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="TotalColorsTextBox" Text="64" Margin="0,0,0,12"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Bits per Channel"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="BitsPerChannelTextBox" Text="2" Margin="0,0,0,12"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Colors per Palette"/>
                <TextBox Grid.Row="3" Grid.Column="0" x:Name="ColorsPerPaletteTextBox" Text="16"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Max Sprites on Screen"/>
                <TextBox Grid.Row="3" Grid.Column="2" x:Name="MaxSpritesTextBox" Text="64"/>
            </Grid>

            <!-- SPRITES -->
            <TextBlock Text="SPRITES" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Sprites per Scanline"/>
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="SpritesPerScanlineTextBox" Text="8"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Max Sprites on Screen"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="MaxSpritesOnScreenTextBox" Text="64"/>
            </Grid>

            <!-- SOUND -->
            <TextBlock Text="SOUND" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Sound Chip"/>
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="SoundChipTextBox" Margin="0,0,0,12"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Tone Channels"/>
                <TextBox Grid.Row="3" Grid.Column="0" x:Name="ToneChannelsTextBox" Text="3"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Noise Channels"/>
                <TextBox Grid.Row="3" Grid.Column="2" x:Name="NoiseChannelsTextBox" Text="1"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
