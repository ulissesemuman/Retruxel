<UserControl x:Class="Retruxel.Views.Wizard.Steps.CodeGenStep2Code"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Code Template" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
        <TextBlock Text="Provide the C code template that will be used to generate code for this module." TextWrapping="Wrap" Margin="0,0,0,24"/>

        <!-- Source selection -->
        <Label Content="Code Source *"/>
        <ComboBox x:Name="SourceComboBox" Margin="0,0,0,16" SelectionChanged="SourceComboBox_SelectionChanged">
            <ComboBoxItem Content="Type code now" IsSelected="True"/>
            <ComboBoxItem Content="Attach existing file"/>
        </ComboBox>

        <!-- File picker (hidden by default) -->
        <StackPanel x:Name="FilePickerPanel" Visibility="Collapsed" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathTextBox" IsReadOnly="True" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Content="Browse..." Click="Browse_Click" Grid.Column="1"/>
            </Grid>
        </StackPanel>

        <!-- Code editor -->
        <Label Content="Code Content (use {{variableName}} for placeholders)"/>
        <TextBox x:Name="CodeTextBox"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 FontFamily="Consolas"
                 FontSize="11"
                 Height="300"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>

        <!-- Info -->
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="16" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="💡 Template Variables" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC">
                    Use double curly braces to define variables that will be replaced from module JSON data.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,8,0,0">
                    Example: {{text}}, {{x}}, {{y}}, {{color}}
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,8,0,0">
                    In the next step, you'll map these variables to JSON paths in the module data.
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
