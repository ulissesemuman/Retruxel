<UserControl x:Class="Retruxel.Tool.Wizard.Views.Steps.TargetStep1BasicInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Basic Information" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>
        <TextBlock Text="Provide the basic information about your target console." TextWrapping="Wrap" Margin="0,0,0,24"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Target ID -->
            <Label Grid.Row="0" Grid.Column="0" Content="Target ID *" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="0" x:Name="TargetIdTextBox" Margin="0,0,0,16"/>

            <!-- Display Name -->
            <Label Grid.Row="0" Grid.Column="2" Content="Display Name *" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="2" x:Name="DisplayNameTextBox" Margin="0,0,0,16"/>

            <!-- Manufacturer -->
            <Label Grid.Row="2" Grid.Column="0" Content="Manufacturer *" Margin="0,0,0,4"/>
            <TextBox Grid.Row="2" Grid.Column="2" x:Name="ManufacturerTextBox" Margin="0,0,0,16"/>

            <!-- Release Year -->
            <Label Grid.Row="3" Grid.Column="0" Content="Release Year" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" Grid.Column="2" x:Name="ReleaseYearTextBox" Text="1980" Margin="0,0,0,16"/>

            <!-- Status -->
            <Label Grid.Row="4" Grid.Column="0" Content="Status" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="4" Grid.Column="2" x:Name="StatusComboBox" Margin="0,0,0,16">
                <ComboBoxItem Content="Active" IsSelected="False"/>
                <ComboBoxItem Content="Scaffolding" IsSelected="True"/>
                <ComboBoxItem Content="Planned" IsSelected="False"/>
            </ComboBox>
        </Grid>

        <!-- Description -->
        <Label Content="Description" Margin="0,8,0,4"/>
        <TextBox x:Name="DescriptionTextBox" 
                 TextWrapping="Wrap" 
                 AcceptsReturn="True" 
                 Height="80" 
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock Text="* Required fields" 
                   FontSize="10" 
                   Foreground="#888888" 
                   Margin="0,16,0,0"/>
    </StackPanel>
</UserControl>
