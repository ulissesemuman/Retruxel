<UserControl x:Class="Retruxel.Views.Wizard.Steps.CodeGenStep4Dependencies"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="DEPENDENCIES"
                   Style="{StaticResource TextTitle}"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Specify any tools that this CodeGen depends on (optional)."
                   Style="{StaticResource TextBody}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>

        <!-- Available tools -->
        <TextBlock Text="REQUIRED TOOLS"
                   Style="{StaticResource TextLabelCaps}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,0,0,4"/>
        <Border Background="{StaticResource BrushSurfaceContainerLow}" Padding="16" Margin="0,0,0,16">
            <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ToolsPanel">
                    <!-- Tools will be added dynamically -->
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Selected tools -->
        <TextBlock Text="SELECTED TOOLS"
                   Style="{StaticResource TextLabelCaps}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,0,0,4"/>
        <Border Background="{StaticResource BrushSurfaceContainerLow}" Padding="16" MinHeight="80">
            <TextBlock x:Name="SelectedToolsText" 
                       Text="No tools selected" 
                       Style="{StaticResource TextLabel}"
                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Info box -->
        <Border Background="{StaticResource BrushSurfaceContainerLow}" Padding="16" Margin="0,24,0,0">
            <StackPanel>
                <TextBlock Text="TOOL DEPENDENCIES"
                           Style="{StaticResource TextLabelCaps}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource TextLabel}"
                           Text="If your CodeGen requires specific tools to run (e.g., image converters, data processors), select them here. The build system will ensure these tools are available before running your CodeGen."/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource TextLabel}"
                           Margin="0,6,0,0"
                           Text="Most CodeGens don't need tool dependencies and can be left empty."/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
