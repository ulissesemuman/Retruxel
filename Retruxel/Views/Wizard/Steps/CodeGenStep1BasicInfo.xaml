<UserControl x:Class="Retruxel.Views.Wizard.Steps.CodeGenStep1BasicInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>

        <TextBlock Text="BASIC INFORMATION"
                   Style="{StaticResource TextTitle}"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Provide basic information about your CodeGen."
                   Style="{StaticResource TextBody}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Module ID -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="MODULE ID *"
                       Style="{StaticResource TextLabelCaps}"
                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                       Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="0"
                     x:Name="ModuleIdTextBox"
                     Margin="0,0,0,16"/>

            <!-- Target ID -->
            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="TARGET ID *"
                       Style="{StaticResource TextLabelCaps}"
                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                       Margin="0,0,0,4"/>
            <Grid Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="TargetIdComboBox" Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Content="INSTALL"
                        Style="{StaticResource ButtonGhost}"
                        Padding="12,0" Height="32"
                        Click="InstallTarget_Click"/>
            </Grid>

            <!-- Display Name -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="DISPLAY NAME *"
                       Style="{StaticResource TextLabelCaps}"
                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                       Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" Grid.Column="0"
                     x:Name="DisplayNameTextBox"
                     Margin="0,0,0,16"/>
        </Grid>

        <!-- Description -->
        <TextBlock Text="DESCRIPTION"
                   Style="{StaticResource TextLabelCaps}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="DescriptionTextBox"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Height="80"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,24"/>

        <!-- Info box — tonal shift, sem borda -->
        <Border Background="{StaticResource BrushSurfaceContainerLow}" Padding="16">
            <StackPanel>
                <TextBlock Text="MODULE AND TARGET IDS"
                           Style="{StaticResource TextLabelCaps}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource TextLabel}"
                           Text="Module ID should match the module you're generating code for — e.g., text.display, sprite, tilemap."/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource TextLabel}"
                           Margin="0,6,0,0"
                           Text="Target ID should match the console target — e.g., sms, nes, gg."/>
            </StackPanel>
        </Border>

        <TextBlock Text="* Required fields"
                   Style="{StaticResource TextLabel}"
                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                   Margin="0,12,0,0"/>

    </StackPanel>
</UserControl>
