<Window x:Class="Retruxel.Tool.LiveLink.LiveLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LIVE LINK — ASSET IMPORTER"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Retruxel;component/Themes/RetruxelTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DropShadowEffect x:Key="WindowShadow"
                              Color="Black" Direction="270"
                              ShadowDepth="8" BlurRadius="32" Opacity="0.6"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="6"
            Background="{StaticResource BrushSurface}"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="24,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="RETRUXEL"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="·"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="LIVE LINK"
                                   Style="{StaticResource TextHeadline}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            Style="{StaticResource ButtonTitleBarClose}"
                            HorizontalAlignment="Right"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT — CONSOLE LOG -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Console header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="24,16">
                        <Grid>
                            <TextBlock Text="CONSOLE"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushPrimary}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnCopyLog"
                                        Content="📋"
                                        Style="{StaticResource ButtonGhost}"
                                        Width="32" Height="32"
                                        FontSize="14"
                                        ToolTip="Copy log"
                                        Click="BtnCopyLog_Click"
                                        Margin="0,0,4,0"/>
                                <Button x:Name="BtnClearLog"
                                        Content="🗑️"
                                        Style="{StaticResource ButtonGhost}"
                                        Width="32" Height="32"
                                        FontSize="14"
                                        ToolTip="Clear log"
                                        Click="BtnClearLog_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Console output -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushSurfaceContainerHighest}">
                        <ScrollViewer x:Name="LogScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="16">
                            <StackPanel x:Name="LogPanel"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- CENTER — PREVIEW -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Preview header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="24,16">
                        <TextBlock Text="PREVIEW"
                                   Style="{StaticResource TextLabelCaps}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Preview area -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushSurfaceContainerHigh}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <Image x:Name="ImgPreview"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Margin="16">
                                <Image.LayoutTransform>
                                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                </Image.LayoutTransform>
                            </Image>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- RIGHT — CONTROLS -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- CONNECTION -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="24,16">
                        <StackPanel>
                            <TextBlock Text="CONNECTION"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushPrimary}"
                                       Margin="0,0,0,12"/>

                            <Button x:Name="BtnConnect"
                                    Content="SELECT ROM &amp; CONNECT"
                                    Style="{StaticResource ButtonPrimary}"
                                    Height="40"
                                    Click="BtnConnect_Click"
                                    Margin="0,0,0,12"/>

                            <TextBlock x:Name="TxtStatus"
                                       Text="Select a ROM to begin"
                                       Style="{StaticResource TextLabel}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- CAPTURE OPTIONS -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushSurface}"
                            Padding="24,16">
                        <StackPanel>
                            <TextBlock Text="CAPTURE OPTIONS"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushPrimary}"
                                       Margin="0,0,0,12"/>

                            <CheckBox x:Name="ChkCaptureTiles"
                                      Content="TILES"
                                      IsChecked="True"
                                      Margin="0,0,0,8"/>
                            
                            <StackPanel x:Name="PanelTileOptions" Margin="20,0,0,8" Visibility="Collapsed">
                                <TextBlock Text="Pattern Table:"
                                           Style="{StaticResource TextLabel}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbPatternTable"
                                          SelectedIndex="0"
                                          Height="32">
                                    <ComboBoxItem Content="0x0000 (BG)"/>
                                    <ComboBoxItem Content="0x1000 (Sprites)"/>
                                    <ComboBoxItem Content="Both (512 tiles)"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <CheckBox x:Name="ChkCaptureNametable"
                                      Content="NAMETABLE"
                                      IsChecked="True"
                                      Margin="0,0,0,8"/>
                            
                            <StackPanel x:Name="PanelNametableOptions" Margin="20,0,0,8" Visibility="Collapsed">
                                <TextBlock Text="Nametable:"
                                           Style="{StaticResource TextLabel}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbNametable"
                                          SelectedIndex="0"
                                          Height="32">
                                    <ComboBoxItem Content="0x2000 (Top-left)"/>
                                    <ComboBoxItem Content="0x2400 (Top-right)"/>
                                    <ComboBoxItem Content="0x2800 (Bottom-left)"/>
                                    <ComboBoxItem Content="0x2C00 (Bottom-right)"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <CheckBox x:Name="ChkCapturePalette"
                                      Content="PALETTE"
                                      IsChecked="True"/>
                        </StackPanel>
                    </Border>

                    <!-- ACTIONS -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushSurfaceContainerLow}"
                            Padding="24,16">
                        <StackPanel VerticalAlignment="Bottom">
                            <TextBlock Text="ACTIONS"
                                       Style="{StaticResource TextLabelCaps}"
                                       Foreground="{StaticResource BrushPrimary}"
                                       Margin="0,0,0,12"/>

                            <Button x:Name="BtnCapture"
                                    Content="CAPTURE"
                                    Style="{StaticResource ButtonSecondary}"
                                    Height="40"
                                    IsEnabled="False"
                                    Click="BtnCapture_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="0,0,6,6"
                    Padding="24,16">
                <Grid>
                    <TextBlock Text="Real-time asset capture from emulator"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               VerticalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnCancel"
                                Content="CANCEL"
                                Style="{StaticResource ButtonSecondary}"
                                Width="120" Height="40"
                                Click="BtnClose_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="BtnImport"
                                Content="IMPORT"
                                Style="{StaticResource ButtonPrimary}"
                                Width="120" Height="40"
                                IsEnabled="False"
                                Click="BtnImport_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
