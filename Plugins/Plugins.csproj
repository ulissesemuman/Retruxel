<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <EnableDefaultItems>false</EnableDefaultItems>
  </PropertyGroup>

  <!-- Include all CodeGens as Content -->
  <ItemGroup>
    <Content Include="CodeGens\**\*.*" />
  </ItemGroup>

  <!-- Prevent build -->
  <Target Name="Build" />
  <Target Name="Rebuild" />
  <Target Name="Clean" />
</Project>
