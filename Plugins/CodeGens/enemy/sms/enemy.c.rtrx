// @retruxel:block source
// Generated by Retruxel — enemy module (SMS). Do not edit manually.
// Pattern: {{pattern}} | Speed: {{speed}}px/frame
#include "SMSlib.h"
#include "enemy.h"

static Enemy enemy;

void enemy_init(void) {
    enemy.x            = {{x}};
    enemy.y            = {{y}};
    enemy.speed        = {{speed}};
    enemy.health       = {{health}};
    enemy.spriteId     = {{spriteId}};
    enemy.direction    = 1;
    enemy.patrolOrigin = {{x}};
    enemy.patrolRange  = {{patrolRange}};
}

void enemy_update(void) {
    if (enemy.health <= 0) return;

{{#if pattern}}
    /* Patrol movement */
    enemy.x += enemy.speed * enemy.direction;

    if (enemy.x >= enemy.patrolOrigin + enemy.patrolRange) {
        enemy.x         = enemy.patrolOrigin + enemy.patrolRange;
        enemy.direction = -1;
    }
    if (enemy.x <= enemy.patrolOrigin) {
        enemy.x         = enemy.patrolOrigin;
        enemy.direction = 1;
    }
{{/if}}
{{#ifnot pattern}}
    /* Static pattern — no movement */
{{/ifnot}}

    SMS_addSprite(enemy.x, enemy.y, enemy.spriteId);
}
// @retruxel:end
