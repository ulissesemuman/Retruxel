<Window x:Class="Retruxel.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Retruxel.Localization"
        Title="{loc:Tr Key='settings.title'}"
        Height="620" Width="860"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <!-- Outer border — CornerRadius 6 permitido: moldura física -->
    <Border Background="{StaticResource BrushSurface}"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="8" BlurRadius="32" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="24,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="RETRUXEL"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="·"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="{loc:Tr Key='settings.title'}"
                                   Style="{StaticResource TextHeadline}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            Style="{StaticResource ButtonTitleBarClose}"
                            HorizontalAlignment="Right"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- ===== BODY ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT NAV ── -->
                <Border Grid.Column="0"
                        Background="{StaticResource BrushSurfaceContainerLow}">
                    <StackPanel Margin="0,16,0,0">

                        <Border x:Name="NavGeneral" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavGeneral_Click">
                            <Grid>
                                <Border x:Name="AccentGeneral" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Visible"/>
                                <TextBlock Text="{loc:Tr Key='settings.nav.general'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushOnSurface}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="NavAppearance" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavAppearance_Click">
                            <Grid>
                                <Border x:Name="AccentAppearance" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Collapsed"/>
                                <TextBlock Text="{loc:Tr Key='settings.nav.appearance'}" Style="{StaticResource TextLabelCaps}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="NavToolchain" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavToolchain_Click">
                            <Grid>
                                <Border x:Name="AccentToolchain" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Collapsed"/>
                                <TextBlock Text="{loc:Tr Key='settings.nav.toolchain'}" Style="{StaticResource TextLabelCaps}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Separator Margin="16,12"/>

                        <TextBlock Text="{loc:Tr Key='settings.nav.targets'}" Style="{StaticResource TextLabelCaps}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   Margin="20,0,0,8"/>

                        <Border x:Name="NavSms" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavSms_Click">
                            <Grid>
                                <Border x:Name="AccentSms" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Collapsed"/>
                                <TextBlock Text="{loc:Tr Key='settings.nav.sms'}" Style="{StaticResource TextLabelCaps}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="NavGg" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavGg_Click">
                            <Grid>
                                <Border x:Name="AccentGg" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Collapsed"/>
                                <TextBlock Text="GAME GEAR" Style="{StaticResource TextLabelCaps}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="NavSg1000" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavSg1000_Click">
                            <Grid>
                                <Border x:Name="AccentSg1000" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Collapsed"/>
                                <TextBlock Text="SG-1000" Style="{StaticResource TextLabelCaps}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="NavColeco" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavColeco_Click">
                            <Grid>
                                <Border x:Name="AccentColeco" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Collapsed"/>
                                <TextBlock Text="COLECOVISION" Style="{StaticResource TextLabelCaps}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="NavNes" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavNes_Click">
                            <Grid>
                                <Border x:Name="AccentNes" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}" Visibility="Collapsed"/>
                                <TextBlock Text="NES" Style="{StaticResource TextLabelCaps}"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ── RIGHT CONTENT ── -->
                <Grid Grid.Column="1" Background="{StaticResource BrushSurface}">

                    <!-- GENERAL PANEL -->
                    <Grid x:Name="PanelGeneral" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabGeneralInterface" Content="{loc:Tr Key='settings.tab.interface'}"
                                        Style="{StaticResource ButtonTabActive}"
                                        Click="TabGeneralInterface_Click"/>
                                <Button x:Name="TabGeneralBehavior" Content="{loc:Tr Key='settings.tab.behavior'}"
                                        Style="{StaticResource ButtonTab}"
                                        Click="TabGeneralBehavior_Click"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <StackPanel x:Name="TabContentGeneralInterface">
                                    <TextBlock Text="{loc:Tr Key='settings.section.language'}" Style="{StaticResource TextLabelCaps}"
                                               Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Tr Key='settings.general.language'}" Style="{StaticResource TextBody}"
                                                           Foreground="{StaticResource BrushOnSurface}"/>
                                                <TextBlock Text="{loc:Tr Key='settings.general.language.desc'}" Style="{StaticResource TextLabel}"/>
                                            </StackPanel>
                                            <ComboBox x:Name="CmbLanguage" Grid.Column="1"
                                                      VerticalAlignment="Center"
                                                      SelectionChanged="CmbLanguage_Changed"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="TabContentGeneralBehavior" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Tr Key='settings.section.startup'}" Style="{StaticResource TextLabelCaps}"
                                               Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Tr Key='settings.general.welcome'}"
                                                           Style="{StaticResource TextBody}"
                                                           Foreground="{StaticResource BrushOnSurface}"/>
                                                <TextBlock Text="{loc:Tr Key='settings.general.welcome.desc'}"
                                                           Style="{StaticResource TextLabel}"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ChkShowWelcome" Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      VerticalAlignment="Center"
                                                      Checked="ChkShowWelcome_Changed"
                                                      Unchecked="ChkShowWelcome_Changed"/>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Tr Key='settings.general.check_updates'}"
                                                           Style="{StaticResource TextBody}"
                                                           Foreground="{StaticResource BrushOnSurface}"/>
                                                <TextBlock Text="{loc:Tr Key='settings.general.check_updates.desc'}"
                                                           Style="{StaticResource TextLabel}"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ChkCheckUpdates" Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      VerticalAlignment="Center"
                                                      Checked="ChkCheckUpdates_Changed"
                                                      Unchecked="ChkCheckUpdates_Changed"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="{loc:Tr Key='settings.section.editor'}" Style="{StaticResource TextLabelCaps}"
                                               Foreground="{StaticResource BrushPrimary}" Margin="0,16,0,8"/>
                                    <Border Style="{StaticResource SettingRow}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{loc:Tr Key='settings.editor.undo_limit'}"
                                                               Style="{StaticResource TextBody}"
                                                               Foreground="{StaticResource BrushOnSurface}"/>
                                                    <TextBlock Text="{loc:Tr Key='settings.editor.undo_limit.desc'}"
                                                               Style="{StaticResource TextLabel}"/>
                                                </StackPanel>
                                                <TextBlock x:Name="TxtUndoHistoryValue" Grid.Column="1"
                                                           Text="32"
                                                           Style="{StaticResource TextBody}"
                                                           Foreground="{StaticResource BrushPrimary}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"/>
                                            </Grid>
                                            <Slider x:Name="SliderUndoHistory"
                                                    Minimum="20" Maximum="100" Value="32"
                                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                                    ValueChanged="SliderUndoHistory_Changed"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- APPEARANCE PANEL -->
                    <Grid x:Name="PanelAppearance" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabAppearanceEditor" Content="{loc:Tr Key='settings.tab.editor'}" Style="{StaticResource ButtonTabActive}"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Key='settings.section.theme'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.theme.current'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="{loc:Tr Key='settings.theme.desc'}"
                                                       Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="BitForge Pro"
                                                   Style="{StaticResource TextBody}"
                                                   Foreground="{StaticResource BrushOnSurface}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- TOOLCHAIN PANEL -->
                    <Grid x:Name="PanelToolchain" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabToolchainGeneral" Content="{loc:Tr Key='settings.tab.general'}" Style="{StaticResource ButtonTabActive}"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Key='settings.section.build_console'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.toolchain.warnings'}"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="{loc:Tr Key='settings.toolchain.warnings.desc'}"
                                                       Style="{StaticResource TextLabel}"
                                                       TextWrapping="Wrap" MaxWidth="400"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkShowWarnings" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="ChkShowWarnings_Changed"
                                                  Unchecked="ChkShowWarnings_Changed"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- TARGET PANEL TEMPLATE (SMS / GG / SG-1000 / ColecoVision / NES) -->
                    <!-- Cada painel tem a mesma estrutura: tab BUILD + seção EMULATOR -->

                    <!-- SMS -->
                    <Grid x:Name="PanelSms" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabSmsBuild" Content="{loc:Tr Key='settings.tab.build'}" Style="{StaticResource ButtonTabActive}"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Key='settings.section.emulator'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.path'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock x:Name="TxtSmsEmulatorPath"
                                                       Style="{StaticResource TextLabel}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="BtnBrowseSmsEmulator" Grid.Column="1"
                                                Content="{loc:Tr Key='settings.browse'}"
                                                Style="{StaticResource ButtonPrimary}"
                                                Padding="16,0" Height="32"
                                                Click="BtnBrowseSmsEmulator_Click"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments'}" Style="{StaticResource TextBody}"
                                                   Foreground="{StaticResource BrushOnSurface}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments.desc'}" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtSmsEmulatorArguments" Padding="8,6"
                                                 TextChanged="TxtSmsEmulatorArguments_Changed"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch.desc'}" Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkSmsLaunchEmulator" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                                  Checked="ChkSmsLaunchEmulator_Changed"
                                                  Unchecked="ChkSmsLaunchEmulator_Changed"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- GAME GEAR -->
                    <Grid x:Name="PanelGg" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabGgBuild" Content="{loc:Tr Key='settings.tab.build'}" Style="{StaticResource ButtonTabActive}"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Key='settings.section.emulator'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.path'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock x:Name="TxtGgEmulatorPath"
                                                       Style="{StaticResource TextLabel}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="BtnBrowseGgEmulator" Grid.Column="1"
                                                Content="{loc:Tr Key='settings.browse'}"
                                                Style="{StaticResource ButtonPrimary}" Padding="16,0" Height="32"
                                                Click="BtnBrowseGgEmulator_Click"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments'}" Style="{StaticResource TextBody}"
                                                   Foreground="{StaticResource BrushOnSurface}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments.desc'}" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtGgEmulatorArguments" Padding="8,6"
                                                 TextChanged="TxtGgEmulatorArguments_Changed"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch.desc'}" Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkGgLaunchEmulator" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                                  Checked="ChkGgLaunchEmulator_Changed"
                                                  Unchecked="ChkGgLaunchEmulator_Changed"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- SG-1000 -->
                    <Grid x:Name="PanelSg1000" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabSg1000Build" Content="{loc:Tr Key='settings.tab.build'}" Style="{StaticResource ButtonTabActive}"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Key='settings.section.emulator'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.path'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock x:Name="TxtSg1000EmulatorPath"
                                                       Style="{StaticResource TextLabel}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="BtnBrowseSg1000Emulator" Grid.Column="1"
                                                Content="{loc:Tr Key='settings.browse'}"
                                                Style="{StaticResource ButtonPrimary}" Padding="16,0" Height="32"
                                                Click="BtnBrowseSg1000Emulator_Click"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments'}" Style="{StaticResource TextBody}"
                                                   Foreground="{StaticResource BrushOnSurface}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments.desc'}" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtSg1000EmulatorArguments" Padding="8,6"
                                                 TextChanged="TxtSg1000EmulatorArguments_Changed"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch.desc'}" Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkSg1000LaunchEmulator" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                                  Checked="ChkSg1000LaunchEmulator_Changed"
                                                  Unchecked="ChkSg1000LaunchEmulator_Changed"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- COLECOVISION -->
                    <Grid x:Name="PanelColeco" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabColecoBuild" Content="{loc:Tr Key='settings.tab.build'}" Style="{StaticResource ButtonTabActive}"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Key='settings.section.emulator'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.path'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock x:Name="TxtColecoEmulatorPath"
                                                       Style="{StaticResource TextLabel}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="BtnBrowseColecoEmulator" Grid.Column="1"
                                                Content="{loc:Tr Key='settings.browse'}"
                                                Style="{StaticResource ButtonPrimary}" Padding="16,0" Height="32"
                                                Click="BtnBrowseColecoEmulator_Click"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments'}" Style="{StaticResource TextBody}"
                                                   Foreground="{StaticResource BrushOnSurface}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments.desc'}" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtColecoEmulatorArguments" Padding="8,6"
                                                 TextChanged="TxtColecoEmulatorArguments_Changed"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch.desc'}" Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkColecoLaunchEmulator" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                                  Checked="ChkColecoLaunchEmulator_Changed"
                                                  Unchecked="ChkColecoLaunchEmulator_Changed"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- NES -->
                    <Grid x:Name="PanelNes" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabNesBuild" Content="{loc:Tr Key='settings.tab.build'}" Style="{StaticResource ButtonTabActive}"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Key='settings.section.emulator'}" Style="{StaticResource TextLabelCaps}"
                                           Foreground="{StaticResource BrushPrimary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.path'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock x:Name="TxtNesEmulatorPath"
                                                       Style="{StaticResource TextLabel}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="BtnBrowseNesEmulator" Grid.Column="1"
                                                Content="{loc:Tr Key='settings.browse'}"
                                                Style="{StaticResource ButtonPrimary}" Padding="16,0" Height="32"
                                                Click="BtnBrowseNesEmulator_Click"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments'}" Style="{StaticResource TextBody}"
                                                   Foreground="{StaticResource BrushOnSurface}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{loc:Tr Key='settings.emulator.arguments.desc'}" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtNesEmulatorArguments" Padding="8,6"
                                                 TextChanged="TxtNesEmulatorArguments_Changed"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch'}" Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="{loc:Tr Key='settings.emulator.launch.desc'}" Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkNesLaunchEmulator" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                                  Checked="ChkNesLaunchEmulator_Changed"
                                                  Unchecked="ChkNesLaunchEmulator_Changed"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>

            <!-- ===== FOOTER ===== -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="0,0,6,6"
                    Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="LblSaved"
                               Style="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            x:Name="BtnClose"
                            Content="{loc:Tr Key='settings.close'}"
                            Style="{StaticResource ButtonPrimary}"
                            Padding="32,0" Height="40"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
