<UserControl x:Class="Retruxel.Views.Wizard.Steps.TargetStep1BasicInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="BASIC INFORMATION" 
                   Style="{StaticResource TextTitle}"
                   Margin="0,0,0,16"/>
        <TextBlock Text="Provide the basic information about your target console." 
                   Style="{StaticResource TextBody}"
                   TextWrapping="Wrap" 
                   Margin="0,0,0,8"/>

        <!-- Console Database Auto-Complete -->
        <Border Background="{StaticResource BrushSurfaceContainerLow}" 
                Padding="16" 
                Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="💡 Quick Fill"
                           Style="{StaticResource TextBody}"
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource BrushPrimary}" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="Select a console from the database to auto-fill specs" 
                           Style="{StaticResource TextBody}"
                           FontSize="10" 
                           Foreground="{StaticResource BrushOnSurfaceVariant}" 
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="ConsoleComboBox" 
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          Height="40"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Target ID -->
            <TextBlock Style="{StaticResource TextLabel}"
                   Grid.Row="0" 
                   Grid.Column="0" 
                   Text="Target ID *" 
                   Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="0" x:Name="TargetIdTextBox" Margin="0,0,0,8"/>

            <!-- Display Name -->
            <TextBlock Style="{StaticResource TextLabel}" Grid.Row="0" Grid.Column="2" Text="Display Name *" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="2" x:Name="DisplayNameTextBox" Margin="0,0,0,8"/>

            <!-- Manufacturer -->
            <TextBlock Style="{StaticResource TextLabel}" Grid.Row="2" Grid.Column="0" Text="Manufacturer *" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" Grid.Column="0" x:Name="ManufacturerTextBox" Margin="0,0,0,8"/>

            <!-- Release Year -->
            <TextBlock Style="{StaticResource TextLabel}" Grid.Row="2" Grid.Column="2" Text="Release Year" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" Grid.Column="2" x:Name="ReleaseYearTextBox" Text="1980" Margin="0,0,0,8"/>

            <!-- Status -->
            <TextBlock Style="{StaticResource TextLabel}" Grid.Row="4" Grid.Column="0" Text="Status" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="5" Grid.Column="0" x:Name="StatusComboBox" Margin="0,0,0,8">
                <ComboBoxItem Content="Active" IsSelected="False"/>
                <ComboBoxItem Content="Scaffolding" IsSelected="True"/>
                <ComboBoxItem Content="Planned" IsSelected="False"/>
            </ComboBox>
        </Grid>

        <!-- Description -->
        <TextBlock Style="{StaticResource TextLabel}" Text="Description"/>
        <TextBox x:Name="DescriptionTextBox" 
                 TextWrapping="Wrap" 
                 AcceptsReturn="True" 
                 Height="80" 
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock Text="* Required fields" 
                   FontSize="10" 
                   Foreground="#888888" 
                   Margin="0,16,0,0"/>
    </StackPanel>
</UserControl>
