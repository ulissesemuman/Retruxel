<Window x:Class="Retruxel.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Retruxel.Services"
        Title="Retruxel"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/assets/Icons/icon.ico">

    <Border CornerRadius="6"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            ClipToBounds="True"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Border.Background>
            <ImageBrush ImageSource="pack://application:,,,/Assets/Images/Splash/background.png"
                        Stretch="UniformToFill"
                        AlignmentX="Center"
                        AlignmentY="Center"/>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ===== TOP BAR ===== -->
            <Grid Grid.Row="0" Margin="24,0">
                <TextBlock Text="{loc:Tr Key='splash.boot_sequence'}"
                           Style="{StaticResource TextLabel}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

            </Grid>

            <!-- ===== CENTER CONTENT ===== -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <!-- Chip icon -->
                <Image Source="pack://application:,,,/Assets/Images/Logo/logochip.png"
                       Width="105" Height="105"
                       Margin="0,0,0,12"
                       HorizontalAlignment="Center"/>

                <!-- App name -->
                <Image Source="pack://application:,,,/Assets/Images/Logo/RETRUXEL.png"
                               Height="36"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="0,0,0,18"/>

                <!-- Subtitle -->
                <TextBlock Text="{loc:Tr Key='splash.subtitle'}"
                           Style="{StaticResource TextLabel}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- Progress bar -->
                <Grid Width="280" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="StatusLabel"
                               Text="{loc:Tr Key='splash.initializing'}"
                               Style="{StaticResource TextLabel}"/>
                    <TextBlock Grid.Column="1"
                               x:Name="PercentLabel"
                               Text="0%"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurface}"/>
                </Grid>

                <Border Width="280" Height="4"
                        Background="{StaticResource BrushSurfaceContainerHighest}"
                        HorizontalAlignment="Center">
                    <Border x:Name="ProgressBar"
                            Background="{StaticResource BrushPrimaryGradient}"
                            HorizontalAlignment="Left"
                            Width="0"/>
                </Border>

                <!-- Log output -->
                <ScrollViewer Width="280" Height="80"
                              Margin="0,16,0,0"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="LogPanel"/>
                </ScrollViewer>

            </StackPanel>

            <!-- ===== BOTTOM BAR ===== -->
            <Grid Grid.Row="3" Margin="24,0">
                <TextBlock x:Name="VersionLabel"
                           Text="v1.0.0-alpha"
                           Style="{StaticResource TextLabel}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

        </Grid>
    </Border>
</Window>