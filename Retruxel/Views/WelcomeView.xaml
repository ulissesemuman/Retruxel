<UserControl x:Class="Retruxel.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Retruxel.Localization"
             xmlns:controls="clr-namespace:Retruxel.Controls"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="16,24">
            <StackPanel>

                <!-- Recent projects header -->
                <TextBlock Text="{loc:Tr Key='welcome.recent_projects'}"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>

                <!-- Recent projects mini list (max 3) -->
                <StackPanel x:Name="SidebarRecentProjects"
                            Margin="0,0,0,16"/>

                <!-- Separator -->
                <Separator Margin="0,0,0,16"/>

                <!-- New project / Open project -->
                <Button Content="{loc:Tr Key='welcome.new_project'}"
                        Style="{StaticResource ButtonPrimary}"
                        Click="NewProject_Click"
                        Margin="0,0,0,8"/>
                <Button Content="{loc:Tr Key='welcome.open_project'}"
                        Style="{StaticResource ButtonGhost}"
                        Click="OpenProject_Click"
                        Margin="0,0,0,20"/>

                <!-- Separator -->
                <Separator Margin="0,0,0,16"/>

                <!-- Documentation / About -->
                <Button Content="{loc:Tr Key='welcome.documentation'}"
                        Style="{StaticResource ButtonToolbar}"
                        HorizontalAlignment="Left"
                        Click="Documentation_Click"
                        Margin="0,0,0,4"/>
                <Button Content="{loc:Tr Key='welcome.about'}"
                        Style="{StaticResource ButtonToolbar}"
                        HorizontalAlignment="Left"
                        Click="About_Click"/>

            </StackPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,32"
                      AllowDrop="True"
                      Drop="MainContent_Drop"
                      DragEnter="MainContent_DragEnter"
                      DragLeave="MainContent_DragLeave">
            <StackPanel>

                <!-- Page title -->
                <TextBlock x:Name="PageTitle"
                           Text="{loc:Tr Key='welcome.title'}"
                           Style="{StaticResource TextDisplay}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="PageDescription"
                           Text="{loc:Tr Key='welcome.subtitle'}"
                           Style="{StaticResource TextBody}"
                           Margin="0,0,0,32"
                           MaxWidth="600"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>

                <!-- Available targets header -->
                <Grid x:Name="TargetHeader" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Section decoration: line + label -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="24" Height="2"
                                Background="{StaticResource BrushPrimary}"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{loc:Tr Key='welcome.available_targets'}"
                                   Style="{StaticResource TextLabelCaps}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Target count: total targets registered in this installation -->
                    <TextBlock x:Name="TargetCount" Grid.Column="2"
                               Style="{StaticResource TextCode}"
                               VerticalAlignment="Center"/>
                    
                </Grid>

                <Border MaxHeight="400">
                    <controls:TargetGridControl x:Name="TargetGrid"
                                                Margin="0,0,0,32"/>
                </Border>

                <!-- Recent projects header -->
                <StackPanel x:Name="RecentProjectsHeader"
                            Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="24" Height="2"
                            Background="{StaticResource BrushPrimary}"
                            VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{loc:Tr Key='welcome.recent_projects'}"
                               Style="{StaticResource TextLabelCaps}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Recent projects list -->
                <StackPanel x:Name="RecentProjectsPanel"/>

                <!-- Empty state (shown when no recent projects) -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,80,0,0">

                    <!-- Logo -->
                    <Image Source="/Assets/Images/Logo/logochip.png"
                               Width="64" Height="64"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="{loc:Tr Key='welcome.empty.title'}"
                               Style="{StaticResource TextDisplay}"
                               FontSize="48"
                               Foreground="{StaticResource BrushPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Tr Key='welcome.empty.subtitle'}"
                               Style="{StaticResource TextLabel}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,32">
                        <Button Content="{loc:Tr Key='welcome.new_project'}"
                                Style="{StaticResource ButtonPrimary}"
                                Click="NewProject_Click"
                                Margin="0,0,8,0"/>
                        <Button Content="{loc:Tr Key='welcome.open_project'}"
                                Style="{StaticResource ButtonGhost}"
                                Click="OpenProject_Click"/>
                    </StackPanel>

                    <Separator Width="300" Margin="0,0,0,16"/>
                    <TextBlock Text="{loc:Tr Key='welcome.empty.drag_hint'}"
                               Style="{StaticResource TextLabel}"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
