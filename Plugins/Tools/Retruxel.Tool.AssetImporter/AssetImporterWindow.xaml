<Window x:Class="Retruxel.Tool.AssetImporter.AssetImporterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asset Importer"
        Height="600" Width="860"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Retruxel;component/Themes/RetruxelTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DropShadowEffect x:Key="WindowShadow"
                              Color="Black" Direction="270"
                              ShadowDepth="8" BlurRadius="32" Opacity="0.6"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer border — CornerRadius 6 permitido: moldura física da janela -->
    <Border CornerRadius="6"
            Background="{StaticResource BrushSurface}"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="24,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitle"
                                   Text="ASSET IMPORTER"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock x:Name="TxtTargetLabel"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Click="BtnClose_Click"
                            Style="{StaticResource ButtonTitleBarClose}"/>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <Grid Grid.Row="1" Margin="24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Asset type selector -->
                <StackPanel x:Name="RegionSelector" Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <TextBlock x:Name="LblType"
                               Text="REGION"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <!-- RadioButtons generated dynamically in code-behind -->
                </StackPanel>

                <!-- BEFORE preview -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock x:Name="LblSource"
                               Text="SOURCE"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,0,0,8"/>
                    <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                            MinHeight="200"
                            AllowDrop="True"
                            Drop="DropZone_Drop"
                            DragOver="DropZone_DragOver"
                            x:Name="DropZone">
                        <Grid>
                            <!-- Drop hint (shown when no image loaded) -->
                            <StackPanel x:Name="DropHint"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtDropHint"
                                           Text="Drop PNG here"
                                           Style="{StaticResource TextBody}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtDropOr"
                                           Text="or"
                                           Style="{StaticResource TextLabel}"
                                           Foreground="{StaticResource BrushOnSurfaceVariant}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4"/>
                                <Button x:Name="BtnBrowse"
                                        Content="BROWSE"
                                        HorizontalAlignment="Center"
                                        Click="BtnBrowse_Click"
                                        Style="{StaticResource ButtonSecondary}"/>
                            </StackPanel>

                            <!-- Source image preview -->
                            <Image x:Name="ImgSource"
                                   Visibility="Collapsed"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Margin="8"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TxtSourceInfo"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- AFTER preview -->
                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock x:Name="LblReduced"
                               Text="REDUCED"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,0,0,8"/>
                    <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                            MinHeight="200">
                        <Grid>
                            <TextBlock x:Name="ReducedHint"
                                       Text="Preview will appear here"
                                       Style="{StaticResource TextLabel}"
                                       Foreground="{StaticResource BrushOnSurfaceVariant}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <Image x:Name="ImgReduced"
                                   Visibility="Collapsed"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Margin="8"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TxtReducedInfo"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Asset name + validation -->
                <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <TextBlock x:Name="LblAssetName"
                                   Text="ASSET NAME"
                                   Style="{StaticResource TextLabelCaps}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBox x:Name="TxtAssetName"
                                 Width="220"
                                 TextChanged="TxtAssetName_TextChanged"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtValidation"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushWarning}"/>
                </StackPanel>
            </Grid>

            <!-- ===== FOOTER ===== -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="0,0,6,6"
                    Padding="24,0">
                <Grid>
                    <TextBlock x:Name="TxtTileCount"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnCancel"
                                Content="CANCEL"
                                Click="BtnCancel_Click"
                                Style="{StaticResource ButtonGhost}"
                                Padding="24,0" Height="40"
                                Margin="0,0,8,0"/>
                        <Button x:Name="BtnImport"
                                Content="IMPORT"
                                IsEnabled="False"
                                Click="BtnImport_Click"
                                Style="{StaticResource ButtonPrimary}"
                                Padding="32,0" Height="40"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
