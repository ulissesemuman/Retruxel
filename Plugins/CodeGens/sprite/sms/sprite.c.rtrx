void sprite_init(void) {
{{#if doubleHeight}}
    // Enable 8x16 double-height sprite mode
    SMS_VDPturnOnFeature(FEATURE_SPRITES_8x16);

{{/if}}
    // Load sprite tile graphics into VRAM at tile slot {{startTile}}
