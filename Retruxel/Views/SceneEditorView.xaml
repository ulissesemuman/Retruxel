<UserControl x:Class="Retruxel.Views.SceneEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="SCENE EDITOR"
                               Style="{StaticResource TextLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Border Background="{StaticResource BrushSurfaceContainerHighest}"
                            Padding="8,0" Height="24">
                        <TextBlock x:Name="TxtSceneName"
                                   Text="scene_01"
                                   Style="{StaticResource TextCode}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Coordinates display -->
                <TextBlock Grid.Column="1"
                           x:Name="TxtCoordinates"
                           Text="X: 0 | Y: 0"
                           Style="{StaticResource TextLabel}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="▶  GENERATE ROM"
                            Style="{StaticResource ButtonPrimary}"
                            Padding="16,0" Height="28"
                            Click="GenerateRom_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== LEFT — MODULE PALETTE ===== -->
        <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="SYSTEM STATUS: NOMINAL"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushPrimary}"
                               Margin="12,4,12,16"
                               FontSize="9"/>

                    <!-- Module categories -->
                    <TextBlock x:Name="ModulePaletteHeader"
                               Text="MODULES"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushPrimary}"
                               Margin="12,0,12,8"/>

                    <StackPanel x:Name="ModulePalettePanel"/>

                    <Border Height="1"
                            Background="{StaticResource BrushGhostBorder}"
                            Margin="12,16"/>

                    <Button Content="+ NEW ASSET"
                            Style="{StaticResource ButtonSecondary}"
                            Margin="12,0"
                            HorizontalAlignment="Stretch"
                            Padding="0,8"/>

                    <TextBlock Text="? DOCUMENTATION"
                               Style="{StaticResource TextLabel}"
                               Margin="12,16,12,0"
                               Cursor="Hand"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== CENTER — CANVAS ===== -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource BrushSurface}">
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="40">

                <!-- Canvas outer glow border -->
                <Border BorderBrush="{StaticResource BrushGhostBorder}"
                        BorderThickness="1"
                        Padding="1">

                    <!-- SMS screen area — 256x192 -->
                    <Canvas x:Name="SceneCanvas"
                            Width="256" Height="192"
                            ClipToBounds="True"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            AllowDrop="True"
                            Drop="Canvas_Drop"
                            DragOver="Canvas_DragOver">

                        <!-- Checkerboard pattern via DrawingBrush -->
                        <Canvas.Background>
                            <DrawingBrush TileMode="Tile"
                                          Viewport="0,0,16,16"
                                          ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#FF0D0D0D">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,16,16"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#FF111111">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,8,8"/>
                                                    <RectangleGeometry Rect="8,8,8,8"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Canvas.Background>

                        <!-- Canvas elements added here dynamically -->

                    </Canvas>
                </Border>

                <!-- Canvas size label -->
                <TextBlock Text="256 × 192 px"
                           Style="{StaticResource TextLabel}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,4,0,-16"/>
            </Grid>
        </ScrollViewer>

        <!-- ===== RIGHT — PROPERTIES ===== -->
        <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                Background="{StaticResource BrushSurfaceContainerLow}"
                Padding="16">
            <StackPanel>
                <TextBlock Text="PROPERTIES"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,16"/>

                <!-- Empty state -->
                <TextBlock x:Name="TxtNoSelection"
                           Text="Select an element on the canvas or in the events panel to edit its properties."
                           Style="{StaticResource TextBody}"
                           TextWrapping="Wrap"
                           Visibility="Visible"/>

                <!-- Properties content — shown when element selected -->
                <StackPanel x:Name="PropertiesPanel"
                            Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- ===== BOTTOM — EVENTS PANEL ===== -->
        <Border Grid.Row="2" Grid.Column="1"
                Background="{StaticResource BrushSurfaceContainerHigh}"
                Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="EVENTS"
                           Style="{StaticResource TextLabel}"
                           Foreground="{StaticResource BrushPrimary}"
                           Margin="0,0,0,8"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="EventsPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>