<Window x:Class="Retruxel.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="620" Width="860"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          Color="Black" Direction="270"
                          ShadowDepth="8" BlurRadius="32" Opacity="0.6"/>

        <!-- Nav item — inactive -->
        <Style x:Key="NavItem" TargetType="Border">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Tab button — inactive -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushOnSurfaceVariant}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource BrushSurfaceContainerHighest}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button — active -->
        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Foreground" Value="{StaticResource BrushOnSurface}"/>
            <Setter Property="Background" Value="{StaticResource BrushSurfaceContainerHighest}"/>
        </Style>

        <!-- Setting row container -->
        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushSurfaceContainerHighest}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Dropdown / ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushOnSurface}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

    </Window.Resources>

    <Border CornerRadius="6"
            Background="{StaticResource BrushSurface}"
            Effect="{StaticResource WindowShadow}"
            Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="24,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="RETRUXEL"
                                   Style="{StaticResource TextHeadline}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="·"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="SETTINGS"
                                   Style="{StaticResource TextHeadline}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Content="✕"
                            Width="32" Height="32"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Foreground="{StaticResource BrushOnSurfaceVariant}"
                            BorderThickness="0"
                            Click="CloseButton_Click"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- ===== BODY ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Left nav -->
                    <ColumnDefinition Width="180"/>
                    <!-- Right content -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT NAV ── -->
                <Border Grid.Column="0"
                        Background="{StaticResource BrushSurfaceContainerLow}">
                    <StackPanel Margin="0,16,0,0">

                        <!-- GENERAL -->
                        <Border x:Name="NavGeneral" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavGeneral_Click">
                            <Grid>
                                <!-- Active accent -->
                                <Border x:Name="AccentGeneral"
                                        Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}"
                                        Visibility="Visible"/>
                                <TextBlock Text="GENERAL"
                                           Style="{StaticResource TextLabel}"
                                           Foreground="{StaticResource BrushOnSurface}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- APPEARANCE -->
                        <Border x:Name="NavAppearance" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavAppearance_Click">
                            <Grid>
                                <Border x:Name="AccentAppearance"
                                        Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}"
                                        Visibility="Collapsed"/>
                                <TextBlock Text="APPEARANCE"
                                           Style="{StaticResource TextLabel}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- TOOLCHAIN -->
                        <Border x:Name="NavToolchain" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavToolchain_Click">
                            <Grid>
                                <Border x:Name="AccentToolchain"
                                        Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}"
                                        Visibility="Collapsed"/>
                                <TextBlock Text="TOOLCHAIN"
                                           Style="{StaticResource TextLabel}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Ghost separator -->
                        <Border Height="1"
                                Background="{StaticResource BrushGhostBorder}"
                                Margin="16,12"/>

                        <!-- TARGETS label -->
                        <TextBlock Text="TARGETS"
                                   Style="{StaticResource TextLabel}"
                                   Foreground="{StaticResource BrushPrimary}"
                                   Margin="20,0,0,8"/>

                        <!-- SMS -->
                        <Border x:Name="NavSms" Style="{StaticResource NavItem}"
                                MouseLeftButtonDown="NavSms_Click">
                            <Grid>
                                <Border x:Name="AccentSms"
                                        Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource BrushPrimary}"
                                        Visibility="Collapsed"/>
                                <TextBlock Text="MASTER SYSTEM"
                                           Style="{StaticResource TextLabel}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ── RIGHT CONTENT ── -->
                <Grid Grid.Column="1" Background="{StaticResource BrushSurface}">

                    <!-- GENERAL PANEL -->
                    <Grid x:Name="PanelGeneral" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tab bar -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TabGeneralInterface"
                                        Content="INTERFACE"
                                        Style="{StaticResource TabButtonActive}"
                                        Click="TabGeneralInterface_Click"/>
                                <Button x:Name="TabGeneralBehavior"
                                        Content="BEHAVIOR"
                                        Style="{StaticResource TabButton}"
                                        Click="TabGeneralBehavior_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Tab content -->
                        <ScrollViewer Grid.Row="1" Padding="24,20"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- INTERFACE tab -->
                                <StackPanel x:Name="TabContentGeneralInterface">

                                    <TextBlock Text="LANGUAGE"
                                               Style="{StaticResource TextLabel}"
                                               Foreground="{StaticResource BrushPrimary}"
                                               Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Language"
                                                           Style="{StaticResource TextBody}"
                                                           Foreground="{StaticResource BrushOnSurface}"/>
                                                <TextBlock Text="UI display language"
                                                           Style="{StaticResource TextLabel}"/>
                                            </StackPanel>
                                            <ComboBox x:Name="CmbLanguage"
                                                      Grid.Column="1"
                                                      VerticalAlignment="Center"
                                                      SelectionChanged="CmbLanguage_Changed"/>
                                        </Grid>
                                    </Border>

                                </StackPanel>

                                <!-- BEHAVIOR tab -->
                                <StackPanel x:Name="TabContentGeneralBehavior"
                                            Visibility="Collapsed">

                                    <TextBlock Text="STARTUP"
                                               Style="{StaticResource TextLabel}"
                                               Foreground="{StaticResource BrushPrimary}"
                                               Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Show Welcome on startup"
                                                           Style="{StaticResource TextBody}"
                                                           Foreground="{StaticResource BrushOnSurface}"/>
                                                <TextBlock Text="Opens the project selection screen when launching"
                                                           Style="{StaticResource TextLabel}"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ChkShowWelcome"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      VerticalAlignment="Center"
                                                      Checked="ChkShowWelcome_Changed"
                                                      Unchecked="ChkShowWelcome_Changed"/>
                                        </Grid>
                                    </Border>

                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- APPEARANCE PANEL -->
                    <Grid x:Name="PanelAppearance" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="EDITOR"
                                        Style="{StaticResource TabButtonActive}"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" Padding="24,20"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <TextBlock Text="TYPOGRAPHY"
                                           Style="{StaticResource TextLabel}"
                                           Foreground="{StaticResource BrushPrimary}"
                                           Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Font size"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="Base font size for the UI"
                                                       Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{StaticResource BrushSurface}"
                                                Padding="8,0" Height="32"
                                                VerticalAlignment="Center">
                                            <TextBox x:Name="TxtFontSize"
                                                     Background="Transparent"
                                                     Foreground="{StaticResource BrushOnSurface}"
                                                     BorderThickness="0"
                                                     FontFamily="{StaticResource FontBody}"
                                                     FontSize="13"
                                                     VerticalAlignment="Center"
                                                     TextAlignment="Center"
                                                     TextChanged="TxtFontSize_Changed"/>
                                        </Border>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- TOOLCHAIN PANEL -->
                    <Grid x:Name="PanelToolchain" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="GENERAL"
                                        Style="{StaticResource TabButtonActive}"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" Padding="24,20"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Placeholder — toolchain settings TBD -->
                                <TextBlock Text="No toolchain settings configured yet."
                                           Style="{StaticResource TextBody}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- SMS PANEL -->
                    <Grid x:Name="PanelSms" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource BrushSurfaceContainerLow}"
                                Padding="16,0" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="BUILD"
                                        Style="{StaticResource TabButtonActive}"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" Padding="24,20"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <TextBlock Text="BUILD CONSOLE"
                                           Style="{StaticResource TextLabel}"
                                           Foreground="{StaticResource BrushPrimary}"
                                           Margin="0,0,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Show toolchain warnings"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="Displays WARNING-level entries from the SMS toolchain in the Build Console"
                                                       Style="{StaticResource TextLabel}"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="400"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkSmsShowWarnings"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="ChkSmsShowWarnings_Changed"
                                                  Unchecked="ChkSmsShowWarnings_Changed"/>
                                    </Grid>
                                </Border>

                                <TextBlock Text="EMULATOR"
                                           Style="{StaticResource TextLabel}"
                                           Foreground="{StaticResource BrushPrimary}"
                                           Margin="0,16,0,8"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Emulator path"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock x:Name="TxtSmsEmulatorPath"
                                                       Text="Not configured"
                                                       Style="{StaticResource TextLabel}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="BtnBrowseSmsEmulator"
                                                Grid.Column="1"
                                                Content="BROWSE"
                                                Style="{StaticResource ButtonPrimary}"
                                                Padding="16,0" Height="32"
                                                Click="BtnBrowseSmsEmulator_Click"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Launch emulator after build"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushOnSurface}"/>
                                            <TextBlock Text="Automatically opens the ROM in the emulator after a successful build"
                                                       Style="{StaticResource TextLabel}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkSmsLaunchEmulator"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="ChkSmsLaunchEmulator_Changed"
                                                  Unchecked="ChkSmsLaunchEmulator_Changed"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>

            <!-- ===== FOOTER ===== -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurfaceContainerLow}"
                    CornerRadius="0,0,6,6"
                    Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="LblSaved"
                               Text=""
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushPrimary}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="CLOSE"
                            Style="{StaticResource ButtonPrimary}"
                            Padding="32,0" Height="40"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
