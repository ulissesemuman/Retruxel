<UserControl x:Class="Retruxel.Views.BuildConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushSurface}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT — TERMINAL ===== -->
        <Grid Grid.Column="0" Margin="32,24,16,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title: "BUILD" + "CONSOLE" em primary -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock x:Name="TxtBuildTitle"   Style="{StaticResource TextDisplay}"/>
                <TextBlock Text=" "                  Style="{StaticResource TextDisplay}"/>
                <TextBlock x:Name="TxtConsoleTitle" Style="{StaticResource TextDisplay}"
                           Foreground="{StaticResource BrushPrimary}"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       x:Name="TxtDescription"
                       Style="{StaticResource TextBody}"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"/>

            <!-- Status row -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatusLabel" Grid.Column="0"
                           Style="{StaticResource TextLabelCaps}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border x:Name="StatusDot"
                            Width="8" Height="8"
                            Background="{StaticResource BrushPrimary}"
                            Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus"
                               Style="{StaticResource TextLabel}"
                               Foreground="{StaticResource BrushPrimary}"/>
                </StackPanel>
            </Grid>

            <!-- Terminal -->
            <Border Grid.Row="3"
                    Background="{StaticResource BrushSurfaceContainerHigh}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Terminal title bar -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceContainerHighest}"
                            Padding="12,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnCopyLog"
                                    Content="📋"
                                    Style="{StaticResource ButtonTitleBar}"
                                    FontSize="14"
                                    Click="CopyLog_Click"
                                    ToolTip="Copy log"/>
                            <Button x:Name="BtnSaveLog"
                                    Content="💾"
                                    Style="{StaticResource ButtonTitleBar}"
                                    FontSize="14"
                                    Click="ExportLog_Click"
                                    ToolTip="Save log"/>
                        </StackPanel>
                    </Border>

                    <!-- Log output -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="LogScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel x:Name="LogPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== RIGHT — EXPORT + STATS ===== -->
        <StackPanel Grid.Column="1" Margin="16,24,32,24">

            <!-- Export options -->
            <TextBlock x:Name="TxtExportOptions"
                       Style="{StaticResource TextLabelCaps}"
                       Margin="0,48,0,12"/>

            <!-- Export ROM card -->
            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16" Margin="0,0,0,8"
                    Cursor="Hand"
                    x:Name="ExportRomCard"
                    MouseLeftButtonDown="ExportRom_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtExportRom"
                                   Style="{StaticResource TextTitle}"/>
                        <TextBlock x:Name="TxtExportRomDesc"
                                   Style="{StaticResource TextLabel}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="↓"
                               FontSize="18"
                               Foreground="{StaticResource BrushPrimary}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Export debug card -->
            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16" Margin="0,0,0,24"
                    Cursor="Hand"
                    x:Name="ExportDebugCard"
                    MouseLeftButtonDown="ExportDebug_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtExportDebug"
                                   Style="{StaticResource TextTitle}"/>
                        <TextBlock x:Name="TxtExportDebugDesc"
                                   Style="{StaticResource TextLabel}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="⬛"
                               FontSize="14"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Verification panel (shown after successful build) -->
            <Border Background="{StaticResource BrushSecondary}"
                    Padding="16" x:Name="VerificationPanel"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="TxtVerification"
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurface}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,4">
                        <TextBlock x:Name="TxtMd5Label"
                                   Style="{StaticResource TextLabelCaps}"/>
                        <TextBlock x:Name="TxtMd5"
                                   Style="{StaticResource TextCode}"
                                   HorizontalAlignment="Right"
                                   MouseLeftButtonDown="CopyMd5_Click"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock x:Name="TxtSha256Label"
                                   Style="{StaticResource TextLabelCaps}"/>
                        <TextBlock x:Name="TxtSha256"
                                   Style="{StaticResource TextCode}"
                                   HorizontalAlignment="Right"
                                   MouseLeftButtonDown="CopySha256_Click"/>
                    </Grid>
                    <TextBlock x:Name="TxtChecks"
                               Style="{StaticResource TextPrimary}"
                               FontSize="10"/>
                </StackPanel>
            </Border>

            <!-- Memory allocation stats (shown after build) -->
            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16" Margin="0,20,0,8">
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="MemoryHeader"
                       Style="{StaticResource TextLabelCaps}"
                       Margin="0,24,0,0"
                       Visibility="Collapsed"/>

                    <StackPanel x:Name="MemoryPanel" Visibility="Collapsed"/>
                </Grid>
            </Border>


            <!-- Total assets (shown after build) -->
            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16" Margin="0,0,0,8"
                    x:Name="TotalAssetsPanel"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="TotalAssetsLabel"
                               Style="{StaticResource TextLabelCaps}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="TotalAssets"
                               Style="{StaticResource TextDisplay}"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Elapsed time (shown after build) -->
            <Border Background="{StaticResource BrushSurfaceContainerHigh}"
                    Padding="16" Margin="0,0,0,8"
                    x:Name="ElapsedTimePanel"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="TxtElapsedTimeLabel"
                               Style="{StaticResource TextLabelCaps}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtElapsedTime"
                               Style="{StaticResource TextDisplay}"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Toast Notification -->
        <Border x:Name="ToastNotification"
                Background="{StaticResource BrushPrimary}"
                Padding="16,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,32"
                Opacity="0"
                Grid.ColumnSpan="2">
            <TextBlock x:Name="ToastText"
                       Style="{StaticResource TextBody}"
                       Foreground="{StaticResource BrushOnPrimary}"
                       FontWeight="Bold"/>
        </Border>

    </Grid>
</UserControl>
