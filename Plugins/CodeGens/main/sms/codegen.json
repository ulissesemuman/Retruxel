{
  "moduleId": "main",
  "targetId": "sms",
  "displayName": "SMS Main File Generator",
  "description": "Generates main.c entry point for Sega Master System",
  "version": "3.0.0",
  "template": "main.c.rtrx",
  "isSystemModule": true,
  "variables": {
    "projectName": {
      "from": "project",
      "path": "name",
      "default": "Untitled"
    },
    "targetId": {
      "from": "project",
      "path": "targetId",
      "default": "sms"
    },
    "timestamp": {
      "from": "system"
    },
    "headers": {
      "from": "moduleFiles",
      "path": "fileType == 'Header' && sourceModuleId != 'retruxel.core' && sourceModuleId != 'retruxel.splash' && sourceModuleId != 'retruxel.engine' && sourceModuleId != 'scene' && sourceModuleId != 'tilemap' && sourceModuleId != 'palette' && sourceModuleId != 'text.display'",
      "transform": "#include \"{{fileName}}\""
    },
    "hasTextDisplay": {
      "from": "moduleFiles",
      "path": "sourceModuleId == 'text.display'",
      "transform": "hasAny"
    },
    "hasGameVars": {
      "from": "moduleFiles",
      "path": "sourceModuleId == 'gamevar'",
      "transform": "hasAny"
    },
    "initialScene": {
      "from": "project",
      "path": "initialSceneId",
      "default": "main"
    },
    "onStartModules": {
      "from": "projectModules",
      "path": "moduleId == 'input' || moduleId == 'physics' || moduleId == 'sprite' || moduleId == 'animation'",
      "transform": "moduleId"
    },
    "onInputModules": {
      "from": "projectModules",
      "path": "moduleId == 'input'",
      "transform": "moduleId"
    },
    "onVBlankModules": {
      "from": "projectModules",
      "path": "moduleId == 'entity' || moduleId == 'enemy' || moduleId == 'scroll'",
      "transform": "moduleId"
    },
    "splashEnabled": {
      "from": "settings",
      "path": "General.ShowMadeWithSplash",
      "default": true
    }
  }
}