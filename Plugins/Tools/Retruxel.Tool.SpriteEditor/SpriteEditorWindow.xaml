<Window x:Class="Retruxel.Tool.SpriteEditor.SpriteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPRITE EDITOR"
        Width="1280" Height="720"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BrushSurface}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Retruxel;component/Themes/RetruxelTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource BrushSurfaceContainerLow}" 
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="SPRITE EDITOR" 
                           Style="{StaticResource TextHeadline}"
                           Foreground="{StaticResource BrushPrimary}"
                           VerticalAlignment="Center" 
                           Margin="16,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="SAVE" Style="{StaticResource ButtonPrimary}" 
                            Click="BtnSave_Click" Width="80" Height="32" Margin="0,0,8,0"/>
                    <Button Content="✕" Style="{StaticResource ButtonTitleBarClose}" 
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Tileset Panel -->
            <Border Grid.Column="0" Background="{StaticResource BrushSurfaceContainerLow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="TILESET" 
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="16,8"/>
                    
                    <ScrollViewer Grid.Row="1" x:Name="TilesetScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="TilesetItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" Width="208"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Center: Composition Canvas -->
            <Border Grid.Column="1" Background="{StaticResource BrushSurface}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="COMPOSITION" 
                               Style="{StaticResource TextLabelCaps}"
                               Foreground="{StaticResource BrushOnSurfaceVariant}"
                               Margin="16,8"/>
                    
                    <ScrollViewer Grid.Row="1" x:Name="CanvasScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="CompositionCanvas" 
                                Width="256" Height="256"
                                Background="{StaticResource BrushSurfaceContainerHigh}"
                                AllowDrop="True"
                                Drop="Canvas_Drop"
                                DragOver="Canvas_DragOver"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: Frames & Animation Panel -->
            <Border Grid.Column="2" Background="{StaticResource BrushSurfaceContainerLow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Frames List -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="FRAMES" 
                                   Style="{StaticResource TextLabelCaps}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   Margin="16,8"/>
                        
                        <ListBox Grid.Row="1" x:Name="FramesListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="FramesListBox_SelectionChanged"/>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                            <Button Content="+" Style="{StaticResource ButtonSecondary}" 
                                    Click="BtnAddFrame_Click" Width="60" Height="32"/>
                            <Button Content="DUPLICATE" Style="{StaticResource ButtonSecondary}" 
                                    Click="BtnDuplicateFrame_Click" Width="90" Height="32" Margin="8,0,0,0"/>
                            <Button Content="−" Style="{StaticResource ButtonSecondary}" 
                                    Click="BtnDeleteFrame_Click" Width="60" Height="32" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Animation Preview -->
                    <Grid Grid.Row="1" Background="{StaticResource BrushSurface}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="48"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="PREVIEW" 
                                   Style="{StaticResource TextLabelCaps}"
                                   Foreground="{StaticResource BrushOnSurfaceVariant}"
                                   Margin="16,8"/>
                        
                        <Border Grid.Row="1" Background="{StaticResource BrushSurfaceContainerHigh}"
                                Margin="16,0">
                            <Canvas x:Name="PreviewCanvas" 
                                    Width="128" Height="128"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                            <Button x:Name="BtnPlayPause" Content="▶" 
                                    Style="{StaticResource ButtonSecondary}" 
                                    Click="BtnPlayPause_Click" Width="40" Height="32"/>
                            <CheckBox x:Name="ChkLoop" Content="LOOP" 
                                      IsChecked="True"
                                      Foreground="{StaticResource BrushOnSurface}"
                                      VerticalAlignment="Center" 
                                      Margin="16,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
